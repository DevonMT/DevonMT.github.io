---
const pathname = Astro.url.pathname.replace(/\/+$/, '') || '/';

const navLinks = [
  { href: '/about',           label: 'About' },
  { href: '/projects',        label: 'Projects' },
  { href: '/blog',            label: 'Writing' },
  { href: '/games/discover',  label: 'Games' },
  { href: '/#now',            label: 'Now' },
];

function isActive(href: string): boolean {
  if (href.includes('#')) return false;
  const target = href.replace(/\/+$/, '') || '/';
  return pathname === target || pathname.startsWith(target + '/');
}
---

<header class="site-nav">
  <div class="nav-inner">
    <a href="/" class="logo" aria-label="devondoes.dev — home">
      <span class="logo-dot" aria-hidden="true"></span>
      <span>devondoes<span class="logo-accent">.dev</span></span>
    </a>

    <input type="checkbox" id="nav-toggle" class="nav-toggle" aria-hidden="true" />
    <label for="nav-toggle" class="nav-burger" aria-label="Toggle navigation">
      <span></span>
      <span></span>
      <span></span>
    </label>

    <nav class="nav-links" aria-label="Primary navigation">
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          class:list={['nav-link', { 'nav-link-active': isActive(href) }]}
          aria-current={isActive(href) ? 'page' : undefined}
        >{label}</a>
      ))}
      <a id="hub-link" href="/hub" class="nav-link nav-link--hub" hidden>// hub</a>
      <button id="lock-link" class="nav-link nav-link--lock" type="button" hidden aria-label="Lock private apps">⊘ lock</button>
      <a href="/#contact" class="nav-cta">Say Hi</a>
    </nav>
  </div>
</header>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(12px);
    background: rgba(10, 14, 39, 0.72);
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
  }

  .nav-inner {
    position: relative;
    max-width: var(--max-width-wide);
    margin: 0 auto;
    padding: 14px 28px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 15px;
    letter-spacing: -0.02em;
    color: var(--color-text);
    text-decoration: none;
  }

  .logo-dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--color-accent-hover);
    box-shadow: 0 0 12px rgba(45, 212, 191, 0.7);
    animation: nav-pulse 2.4s ease-in-out infinite;
    flex-shrink: 0;
  }

  .logo-accent {
    color: var(--color-accent-hover);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .nav-link {
    padding: 7px 12px;
    border-radius: var(--radius-sm);
    font-size: 13.5px;
    color: var(--color-text-muted);
    font-weight: 500;
    text-decoration: none;
    transition: color var(--transition), background var(--transition);
  }

  .nav-link:hover {
    color: var(--color-text);
    background: rgba(255, 255, 255, 0.05);
  }

  .nav-link-active {
    color: var(--color-accent-hover) !important;
  }

  .nav-link--hub {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-accent);
    opacity: 0.75;
  }
  .nav-link--hub:hover {
    opacity: 1;
    background: var(--color-accent-soft);
    color: var(--color-accent);
  }

  .nav-link--lock {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-text-faint);
    background: none;
    border: none;
    cursor: pointer;
  }
  .nav-link--lock:hover {
    color: var(--color-danger);
    background: rgba(248, 113, 113, 0.08);
  }

  .nav-cta {
    margin-left: 6px;
    padding: 8px 15px;
    border-radius: var(--radius-sm);
    font-size: 13.5px;
    font-weight: 600;
    color: var(--color-bg);
    background: var(--color-accent-hover);
    text-decoration: none;
    transition: background var(--transition);
  }

  .nav-cta:hover {
    background: var(--color-accent-light);
  }

  /* ── Mobile hamburger (hidden on desktop) ─────────────────── */
  .nav-toggle {
    display: none;
  }

  .nav-burger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 2.5rem;
    height: 2.5rem;
    padding: 0.5rem;
    cursor: pointer;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: var(--radius-sm);
    background: rgba(255, 255, 255, 0.03);
  }

  .nav-burger span {
    display: block;
    height: 2px;
    width: 100%;
    background: var(--color-text);
    border-radius: 2px;
    transition: transform var(--transition), opacity var(--transition);
  }

  @media (max-width: 640px) {
    .nav-burger {
      display: flex;
    }

    .nav-links {
      position: absolute;
      top: calc(100% + 0.5rem);
      right: 0;
      left: 0;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      z-index: 60;
      padding: 8px;
      background: rgba(13, 19, 34, 0.98);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      max-height: 0;
      overflow: hidden;
      opacity: 0;
      transform: translateY(-6px);
      transition: max-height var(--transition), opacity var(--transition),
        transform var(--transition);
      pointer-events: none;
    }

    .nav-link {
      display: block;
      padding: 12px 14px;
      font-size: 15px;
      border-radius: var(--radius-sm);
    }

    .nav-link-active {
      background: var(--color-accent-soft);
    }

    .nav-cta {
      margin-left: 0;
      margin-top: 4px;
      text-align: center;
      padding: 12px 14px;
      font-size: 15px;
    }

    .nav-toggle:checked ~ .nav-links {
      max-height: 22rem;
      opacity: 1;
      transform: translateY(0);
      pointer-events: auto;
    }

    /* Animate burger into an X when open */
    .nav-toggle:checked ~ .nav-burger span:nth-child(1) {
      transform: translateY(7px) rotate(45deg);
    }
    .nav-toggle:checked ~ .nav-burger span:nth-child(2) {
      opacity: 0;
    }
    .nav-toggle:checked ~ .nav-burger span:nth-child(3) {
      transform: translateY(-7px) rotate(-45deg);
    }
  }

  @keyframes nav-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.45; transform: scale(0.82); }
  }

  @media (prefers-reduced-motion: reduce) {
    .logo-dot { animation: none; }
    .nav-link, .nav-cta, .nav-burger span { transition: none; }
  }
</style>

<script>
  // Close the mobile menu after a nav link is tapped.
  const toggle = document.getElementById('nav-toggle') as HTMLInputElement | null;
  if (toggle) {
    document.querySelectorAll('.site-nav .nav-links a').forEach((link) => {
      link.addEventListener('click', () => {
        toggle.checked = false;
      });
    });
  }

  // Reveal the private hub + lock controls if the access key is present.
  const hubLink = document.getElementById('hub-link');
  const lockLink = document.getElementById('lock-link');
  if (localStorage.getItem('devon_key')) {
    hubLink?.removeAttribute('hidden');
    lockLink?.removeAttribute('hidden');
  }

  // Lock = forget the saved key everywhere and reload (drops private pages to their gate).
  lockLink?.addEventListener('click', () => {
    localStorage.removeItem('devon_key');
    location.reload();
  });
</script>
