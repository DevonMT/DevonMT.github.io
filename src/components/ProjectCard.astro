---
import type { Project } from '../data/projects';

export interface Props {
  project: Project;
}

const { project } = Astro.props;
const body = project.longDescription ?? project.description;

const statusLabel: Record<Project['status'], string> = {
  active: 'active',
  complete: 'complete',
  archived: 'archived',
};
---

<article class="project-card">
  <div class="card-head">
    <h3>{project.title}</h3>
    <span class:list={['status', project.status]} aria-label={`Status: ${statusLabel[project.status]}`}>
      <span class="status-dot" aria-hidden="true"></span>
      {statusLabel[project.status]}
    </span>
  </div>

  <p class="card-desc">{body}</p>

  <ul class="card-tags" aria-label="Tech used">
    {project.tags.map((tag) => <li class="tag">{tag}</li>)}
  </ul>

  {
    (project.repo || project.demo) && (
      <div class="card-links">
        {project.repo && (
          <a href={project.repo} target="_blank" rel="noopener noreferrer">
            Code ↗
          </a>
        )}
        {project.demo && (
          <a href={project.demo} target="_blank" rel="noopener noreferrer">
            Demo ↗
          </a>
        )}
      </div>
    )
  }
</article>

<style>
  .card-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-sm);
    margin-bottom: var(--space-xs);
  }
  .card-head h3 {
    margin-bottom: 0;
  }

  .status {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    flex-shrink: 0;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    text-transform: lowercase;
    color: var(--color-text-faint);
  }

  .status-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 999px;
    background: var(--color-text-faint);
  }

  /* active = teal dot + glow, complete = muted, archived = faint */
  .status.active {
    color: var(--color-accent);
  }
  .status.active .status-dot {
    background: var(--color-accent);
    box-shadow: 0 0 0 3px var(--color-accent-soft);
  }

  .status.complete {
    color: var(--color-text-muted);
  }
  .status.complete .status-dot {
    background: var(--color-text-muted);
  }

  .status.archived {
    color: var(--color-text-faint);
    opacity: 0.8;
  }
</style>
