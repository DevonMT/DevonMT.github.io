---
import type { Project } from '../data/projects';

export interface Props {
  project: Project;
}

const { project: p } = Astro.props;
const body = p.longDescription ?? p.description;

// Internal demos (e.g. "/games/discover") open in the same tab; external ones open in a new tab.
const demoIsInternal = !!p.demo && p.demo.startsWith('/');

const amber = p.tagColor === 'amber';
const chipStyle = amber
  ? 'color:var(--color-amber);background:var(--color-amber-bg)'
  : 'color:var(--color-accent-light);background:var(--color-accent-soft)';
const strokeColor = amber ? 'var(--color-amber)' : 'var(--color-accent-hover)';

const statusColors: Record<Project['status'], { dot: string; label: string }> = {
  active:   { dot: 'var(--color-accent-hover)', label: 'var(--color-accent-hover)' },
  complete: { dot: 'var(--color-text-muted)',   label: 'var(--color-text-muted)' },
  archived: { dot: 'var(--color-text-faint)',   label: 'var(--color-text-faint)' },
};
const sc = statusColors[p.status];
---

<article class="pj-card" data-pj-card>
  <div class="pj-top">
    <span class="pj-tag" style={chipStyle}>{p.tag}</span>
    <div class="pj-status">
      {p.status === 'active' && <span class="status-pulse" aria-hidden="true"></span>}
      <span class="status-dot" style={`background:${sc.dot}`} aria-hidden="true"></span>
      <span class="status-label" style={`color:${sc.label}`}>{p.status}</span>
    </div>
  </div>

  <svg viewBox="0 0 140 40" class="pj-spark" aria-hidden="true">
    <polyline
      data-spark
      points={p.sparkline}
      fill="none"
      stroke={strokeColor}
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      style="stroke-dasharray:220;stroke-dashoffset:0"
    />
  </svg>

  <h3 class="pj-title">{p.title}</h3>
  <p class="pj-body">{body}</p>

  <div class="pj-stack">
    {p.tags.map((t, i) => (
      <>
        <span class="stack-item">{t}</span>
        {i < p.tags.length - 1 && <span class="stack-sep" aria-hidden="true">·</span>}
      </>
    ))}
  </div>

  {(p.repo || p.demo) && (
    <div class="pj-links">
      {p.repo && (
        <a href={p.repo} target="_blank" rel="noopener noreferrer" class="pj-link">Code ↗</a>
      )}
      {p.demo && (
        demoIsInternal ? (
          <a href={p.demo} class="pj-link">Demo →</a>
        ) : (
          <a href={p.demo} target="_blank" rel="noopener noreferrer" class="pj-link">Demo ↗</a>
        )
      )}
    </div>
  )}
</article>

<style>
  .pj-card {
    position: relative;
    border-radius: var(--radius);
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    padding: 22px;
    display: flex;
    flex-direction: column;
    gap: 0;
    transition: transform var(--transition-slow), border-color var(--transition-slow), box-shadow var(--transition-slow);
  }

  .pj-card:hover {
    transform: translateY(-5px);
    border-color: color-mix(in srgb, var(--color-accent-hover) 35%, transparent);
    box-shadow: var(--shadow-card);
  }

  .pj-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
  }

  .pj-tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11.5px;
    padding: 4px 9px;
    border-radius: 6px;
  }

  .pj-status {
    display: flex;
    align-items: center;
    gap: 6px;
    position: relative;
  }

  .status-pulse {
    position: absolute;
    left: -2px;
    top: -2px;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--color-accent-soft);
    animation: card-pulse 2s ease-in-out infinite;
  }

  .status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
    position: relative;
    z-index: 1;
  }

  .status-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.04em;
  }

  .pj-spark {
    width: 100%;
    height: 46px;
    margin-bottom: 18px;
    display: block;
  }

  .pj-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 20px;
    margin: 0 0 10px;
    color: var(--color-text);
    line-height: 1.2;
  }

  .pj-body {
    font-size: 14px;
    line-height: 1.6;
    color: var(--color-text-muted);
    margin: 0 0 18px;
    flex: 1;
  }

  .pj-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    align-items: center;
    margin-bottom: 16px;
  }

  .stack-item {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-text-faint);
  }

  .stack-sep {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-text-dark);
  }

  .pj-links {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-top: auto;
    padding-top: 4px;
  }

  .pj-link {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 500;
    color: var(--color-text-muted);
    text-decoration: none;
    padding: 6px 12px;
    border-radius: var(--radius-xs);
    border: 1px solid rgba(255, 255, 255, 0.1);
    transition: color var(--transition), border-color var(--transition);
  }

  .pj-link:hover {
    color: var(--color-accent-hover);
    border-color: color-mix(in srgb, var(--color-accent-hover) 40%, transparent);
  }

  @keyframes card-pulse {
    0%, 100% { opacity: 0.6; transform: scale(1); }
    50% { opacity: 0; transform: scale(1.8); }
  }

  @keyframes drawline {
    from { stroke-dashoffset: 220; }
    to { stroke-dashoffset: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .pj-card { transition: none; }
    .status-pulse { animation: none; }
  }
</style>

<script>
  document.querySelectorAll('[data-pj-card]').forEach((card) => {
    const path = card.querySelector('[data-spark]') as SVGElement | null;
    card.addEventListener('mouseenter', () => {
      if (path) {
        path.style.animation = 'none';
        void (path as unknown as Element).getBoundingClientRect();
        path.style.animation = 'drawline .85s ease forwards';
      }
    });
  });
</script>
