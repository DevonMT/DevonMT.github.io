---
---

<footer class="sub-footer">
  <div class="footer-copy">© 2026 Devon Troedel · built with Astro, deployed on GitHub Pages</div>
  <div class="footer-right">
    <a href="https://github.com/DevonMT" target="_blank" rel="noopener" class="footer-link">GitHub</a>
    <span class="footer-sep" aria-hidden="true">·</span>
    <a href="https://linkedin.com/in/dtroedel" target="_blank" rel="noopener" class="footer-link">LinkedIn</a>
    <span class="footer-sep" aria-hidden="true">|</span>
    <span id="sub-clock">--:--:-- CT</span>
  </div>
</footer>

<style>
  .sub-footer {
    padding: 36px 0 52px;
    margin-top: 60px;
    border-top: 1px solid rgba(255, 255, 255, 0.07);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }

  .footer-copy {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-text-faint);
  }

  .footer-right {
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-text-faint);
  }

  .footer-link {
    color: var(--color-text-faint);
    text-decoration: none;
    transition: color var(--transition);
  }

  .footer-link:hover {
    color: var(--color-accent-hover);
  }

  .footer-sep {
    color: var(--color-text-dark);
  }
</style>

<script>
  const el = document.getElementById('sub-clock');
  function tick() {
    if (!el) return;
    try {
      el.textContent = new Date().toLocaleTimeString('en-US', {
        hour12: false,
        timeZone: 'America/Chicago',
      }) + ' CT';
    } catch {
      el.textContent = new Date().toLocaleTimeString();
    }
  }
  tick();
  setInterval(tick, 1000);
</script>
