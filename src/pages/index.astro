    align-items: center;
    gap: 10px;
  }

  .now-dot {
    width: 13px;
    height: 13px;
    border-radius: 50%;
    background: var(--ac);
    box-shadow: 0 0 16px color-mix(in srgb, var(--ac) 80%, transparent);
    animation: pulse 2.4s ease-in-out infinite;
    display: block;
  }

  .now-live {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: #616d8c;
    writing-mode: vertical-rl;
    letter-spacing: 0.1em;
  }

  .now-h2 {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 600;
    font-size: 26px;
    letter-spacing: -0.02em;
    margin: 0 0 12px;
    color: #f4f7fd;
  }

  .now-p {
    font-size: 16.5px;
    line-height: 1.6;
    color: #9aa6c2;
    margin: 0;
    max-width: 620px;
  }

  /* ── Contact ────────────────────────────────────────────────────── */
  .contact-h2 {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 44px;
    letter-spacing: -0.03em;
    margin: 0 0 28px;
    color: #f4f7fd;
    max-width: 680px;
    line-height: 1.05;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 14px;
  }

  .contact-card {
    display: block;
    padding: 20px;
    border-radius: 13px;
    background: #0e1424;
    border: 1px solid rgba(255, 255, 255, 0.08);
    text-decoration: none;
    transition: transform 0.2s, border-color 0.2s;
  }

  .contact-card:hover {
    transform: translateY(-3px);
    border-color: color-mix(in srgb, var(--ac) 45%, transparent);
  }

  .contact-card-amber:hover {
    border-color: rgba(240, 168, 104, 0.45);
  }

  .contact-card-email {
    background: linear-gradient(
      135deg,
      color-mix(in srgb, var(--ac) 10%, transparent),
      rgba(240, 168, 104, 0.08)
    );
    border-color: color-mix(in srgb, var(--ac) 25%, transparent);
    cursor: pointer;
  }

  .contact-card-email:hover {
    border-color: color-mix(in srgb, var(--ac) 60%, transparent) !important;
  }

  .contact-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: #616d8c;
    margin-bottom: 6px;
  }

  .contact-label-email {
    color: var(--ac-soft);
  }

  .contact-noscript {
    margin-top: 14px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    color: #9aa6c2;
  }

  .contact-title {
    font-weight: 600;
    font-size: 15px;
    color: #e9edf7;
  }

  /* ── Footer ─────────────────────────────────────────────────────── */
  .site-footer {
    padding: 40px 0 56px;
    margin-top: 30px;
    border-top: 1px solid rgba(255, 255, 255, 0.07);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    flex-wrap: wrap;
  }

  .footer-copy {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: #616d8c;
  }

  .footer-right {
    display: flex;
    align-items: center;
    gap: 16px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: #616d8c;
  }

  #clock-wrap {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .pipe {
    color: #2a3450;
  }

  #egg-hint {
    cursor: help;
  }

  /* ── Keyframes ──────────────────────────────────────────────────── */
  @keyframes blink {
    0%, 49% { opacity: 1; }
    50%, 100% { opacity: 0; }
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.45; transform: scale(0.82); }
  }

  @keyframes drawline {
    from { stroke-dashoffset: 220; }
    to { stroke-dashoffset: 0; }
  }

  @keyframes flashcell {
    0% { background: rgba(240, 168, 104, 0.35); }
    100% { background: transparent; }
  }

  /* ── Responsive ─────────────────────────────────────────────────── */
  @media (max-width: 900px) {
    .hero {
      grid-template-columns: 1fr;
      gap: 36px;
      padding: 56px 0 56px;
    }
    h1 { font-size: 56px; }
    .projects-grid { grid-template-columns: repeat(2, 1fr); }
    .contact-grid { grid-template-columns: repeat(2, 1fr); }
    .about-grid { gap: 32px; }
  }

  @media (max-width: 640px) {
    .page-content { padding: 0 20px; }

    .hero { padding: 40px 0 44px; }
    .hero-eyebrow { margin-bottom: 16px; }
    h1 { font-size: 44px; }
    .hero-p { font-size: 16px; }

    .query-card-wrap { display: none; }

    .stats { grid-template-columns: 1fr; gap: 12px; padding-bottom: 56px; }

    .section { padding: 28px 0 56px; }
    .section-h2 { font-size: 26px; }

    .about-grid { grid-template-columns: 1fr; }
    .about-h2 { font-size: 26px; }

    .projects-grid { grid-template-columns: 1fr; }

    .now-panel {
      grid-template-columns: 1fr;
      padding: 28px 24px;
      gap: 18px;
    }
    .now-rail { flex-direction: row; gap: 8px; }
    .now-live { writing-mode: horizontal-tb; }

    .contact-grid { grid-template-columns: 1fr; }
    .contact-h2 { font-size: 32px; }

    .writing-head { flex-wrap: wrap; }

    .post-row { grid-template-columns: 64px 1fr; gap: 12px; }
    .post-tag { display: none; }

    .site-footer { flex-direction: column; align-items: flex-start; gap: 14px; }
  }

  /* ── Reduced motion ─────────────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .logo-dot, .now-dot, .cursor { animation: none; }
    .pj-card, .btn-primary, .btn-secondary, .contact-card, .nav-link, .post-row { transition: none; }
  }
</style>

<script>
  const roles = [
    'builds Snowflake warehouses',
    'ships dashboards people trust',
    'automates the boring parts',
    'breaks weekend projects (lovingly)',
    'turns data into decisions',
  ];

  const vibes = [
    'BI Nerd',
    'caffeine → SQL',
    'dashboard whisperer',
    'professionally curious',
    'recovering spreadsheet user',
    'data plumber',
  ];

  // Typing role rotator
  const roleEl = document.getElementById('role');
  let ri = 0, ci = 0, deleting = false;

  function type() {
    if (!roleEl) return;
    const word = roles[ri];
    if (!deleting) {
      ci++;
      roleEl.textContent = word.slice(0, ci);
      if (ci === word.length) {
        deleting = true;
        setTimeout(type, 1900);
      } else {
        setTimeout(type, 55 + Math.random() * 45);
      }
    } else {
      ci--;
      roleEl.textContent = word.slice(0, ci);
      if (ci === 0) {
        deleting = false;
        ri = (ri + 1) % roles.length;
        setTimeout(type, 380);
      } else {
        setTimeout(type, 28);
      }
    }
  }
  setTimeout(type, 2200);

  // Count-up stats
  function runCountup(el: Element) {
    const target = parseInt(el.getAttribute('data-countup') || '0', 10);
    const dur = 900;
    const start = performance.now();
    function step(now: number) {
      const p = Math.min((now - start) / dur, 1);
      const eased = 1 - Math.pow(1 - p, 3);
      el.textContent = String(Math.round(eased * target));
      if (p < 1) requestAnimationFrame(step);
      else el.textContent = String(target);
    }
    requestAnimationFrame(step);
  }

  const countupEls = document.querySelectorAll('[data-countup]');
  if ('IntersectionObserver' in window) {
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((en) => {
          if (en.isIntersecting) {
            runCountup(en.target);
            io.unobserve(en.target);
          }
        });
      },
      { threshold: 0.6 },
    );
    countupEls.forEach((el) => io.observe(el));
  } else {
    countupEls.forEach(runCountup);
  }

  // Project card hover: redraw sparkline
  document.querySelectorAll('[data-pj]').forEach((card) => {
    const path = card.querySelector('[data-spark]') as SVGElement | null;
    card.addEventListener('mouseenter', () => {
      if (path) {
        path.style.animation = 'none';
        void (path as unknown as Element).getBoundingClientRect();
        path.style.animation = 'drawline .85s ease forwards';
      }
    });
  });

  // Runnable query: cycle vibe cell
  let vi = 0;
  const btn = document.getElementById('run-btn');
  const cell = document.getElementById('vibe-cell');
  const rtime = document.getElementById('run-time');

  if (btn && cell) {
    btn.addEventListener('click', () => {
      vi = (vi + 1) % vibes.length;
      cell.textContent = vibes[vi];
      cell.style.animation = 'none';
      void cell.offsetWidth;
      cell.style.animation = 'flashcell .6s ease';
      if (rtime) {
        rtime.textContent = 'executed in 0.0' + (2 + Math.floor(Math.random() * 7)) + 's';
      }
    });
  }

  // Live clock (Central Time)
  const clock = document.getElementById('clock');
  function tick() {
    if (!clock) return;
    try {
      const t = new Date().toLocaleTimeString('en-US', {
        hour12: false,
        timeZone: 'America/Chicago',
      });
      clock.textContent = t + ' CT';
    } catch {
      clock.textContent = new Date().toLocaleTimeString();
    }
  }
  tick();
  setInterval(tick, 1000);

  // Console easter egg
  function printEgg() {
    console.log('%c-- query result --', 'color:#f0a868;font-family:monospace;font-size:13px;');
    console.log('%c| name     | Devon Troedel              |', 'color:#2dd4bf;font-family:monospace;');
    console.log('%c| role     | Data Engineer              |', 'color:#2dd4bf;font-family:monospace;');
    console.log('%c| status   | probably querying           |', 'color:#2dd4bf;font-family:monospace;');
    console.log('%c| say hi   | linkedin.com/in/dtroedel   |', 'color:#7ee0d0;font-family:monospace;');
    console.log('%c| games    | invite-only — ask me for a key |', 'color:#616d8c;font-family:monospace;');
    console.log('%c1 row in set (0.00 sec). nice, a fellow console-opener.', 'color:#616d8c;font-family:monospace;');
  }
  printEgg();

  const eggHint = document.getElementById('egg-hint');
  if (eggHint) {
    eggHint.addEventListener('click', printEgg);
    eggHint.addEventListener('keydown', (e) => {
      if ((e as KeyboardEvent).key === 'Enter') printEgg();
    });
  }

  // Assemble the contact email at runtime so address-harvesting bots that don't
  // run JS never see it. The static HTML only carries the user/domain parts.
  const emailCard = document.getElementById('email-card');
  if (emailCard) {
    const user = emailCard.getAttribute('data-u');
    const domain = emailCard.getAttribute('data-d');
    if (user && domain) {
      const subject = encodeURIComponent('Hi from devontroedel.com');
      emailCard.setAttribute('href', `mailto:${user}@${domain}?subject=${subject}`);
    }
  }
</script>
