---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { featuredProjects } from '../data/projects';
import { getCollection } from 'astro:content';

const email = 'devon.troedel@gmail.com';

const stack = ['SQL', 'Python', 'Power BI', 'Data Engineering', 'ETL', 'Streamlit'];

const recentPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const dateFmt = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout>
  <Header />
  <main>
    <section class="hero">
      <p class="eyebrow mono">// devondoes.dev</p>

      <h1>Devon Troedel</h1>

      <p class="tagline">
        Data engineer. BI nerd. I wrangle data into things people actually use —
        pipelines, dashboards, automations, and the occasional weekend project
        that got a little out of hand.
      </p>

      <ul class="stack" aria-label="Tech stack">
        {stack.map((tech) => <li class="tag">{tech}</li>)}
      </ul>

      <div class="actions">
        <a class="btn btn-primary" href="/projects">View Projects</a>
        <a class="btn" href={`mailto:${email}`}>Get in touch</a>
      </div>
    </section>

    <section class="section" aria-labelledby="featured-heading">
      <div class="section-head">
        <h2 id="featured-heading">Featured Projects</h2>
        <a class="section-link mono" href="/projects">All projects →</a>
      </div>

      <div class="card-grid">
        {featuredProjects.map((project) => <ProjectCard project={project} />)}
      </div>
    </section>

    {
      recentPosts.length > 0 && (
        <section class="section" aria-labelledby="posts-heading">
          <div class="section-head">
            <h2 id="posts-heading">Recent Posts</h2>
            <a class="section-link mono" href="/blog">All posts →</a>
          </div>

          <ul class="post-list">
            {recentPosts.map((post) => (
              <li class="blog-card">
                <p class="blog-meta mono">
                  <time datetime={post.data.date.toISOString()}>
                    {dateFmt.format(post.data.date)}
                  </time>
                </p>
                <h3>
                  <a href={`/blog/${post.slug}`}>{post.data.title}</a>
                </h3>
                <p class="card-desc">{post.data.excerpt}</p>
                <a class="read-more mono" href={`/blog/${post.slug}`}>
                  Read more →
                </a>
              </li>
            ))}
          </ul>
        </section>
      )
    }

  </main>
  <Footer />
</BaseLayout>

<style>
  .hero {
    min-height: 62vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    gap: var(--space-md);
    padding-block: var(--space-2xl) var(--space-xl);
  }

  .eyebrow {
    color: var(--color-accent);
    font-size: 0.9rem;
    letter-spacing: 0.04em;
    margin-bottom: var(--space-xs);
  }

  h1 {
    background: linear-gradient(120deg, var(--color-text) 30%, var(--color-accent) 120%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .tagline {
    font-size: clamp(1.1rem, 2.5vw, 1.4rem);
    color: var(--color-text-muted);
    max-width: 42ch;
    line-height: 1.5;
  }

  .accent {
    color: var(--color-accent);
    font-weight: 500;
  }

  .stack {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    margin-block: var(--space-xs);
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-top: var(--space-xs);
  }
</style>
