---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { featuredProjects } from '../data/projects';

const email = 'devon.troedel@gmail.com';

const stack = ['SQL', 'Python', 'Power BI', 'Data Engineering', 'ETL', 'Streamlit'];

const recentPosts = [
  {
    title: 'Building a Finance Dashboard with Plaid',
    date: '2026-05-28',
    excerpt:
      'How I wired Plaid into a local SQLite database and built a Streamlit dashboard to track my own spending — and the privacy tradeoffs that shaped the design.',
    slug: '#',
  },
  {
    title: 'Why I Use SQLite for Everything',
    date: '2026-05-10',
    excerpt:
      'SQLite is not a toy. For most of the tools I build, a single file beats a database server. Here is when it works, and the few times it does not.',
    slug: '#',
  },
  {
    title: 'Streamlit Is My Default UI',
    date: '2026-04-22',
    excerpt:
      'For internal tools and personal projects, reaching for Streamlit instead of a frontend framework saves me days. A look at where it shines and where it bites.',
    slug: '#',
  },
];

const fmtDate = (iso: string) =>
  new Date(iso).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
---

<BaseLayout>
  <Header />
  <main>
    <section class="hero">
      <p class="eyebrow mono">// devondoes.dev</p>

      <h1>Devon Troedel</h1>

      <p class="tagline">
        Data engineer. BI nerd. I wrangle data into things people actually use —
        pipelines, dashboards, automations, and the occasional weekend project
        that got a little out of hand.
      </p>

      <ul class="stack" aria-label="Tech stack">
        {stack.map((tech) => <li class="tag">{tech}</li>)}
      </ul>

      <div class="actions">
        <a class="btn btn-primary" href="/projects">View Projects</a>
        <a class="btn" href={`mailto:${email}`}>Get in touch</a>
      </div>
    </section>

    <section class="section" aria-labelledby="featured-heading">
      <div class="section-head">
        <h2 id="featured-heading">Featured Projects</h2>
        <a class="section-link mono" href="/projects">All projects →</a>
      </div>

      <div class="card-grid">
        {featuredProjects.map((project) => <ProjectCard project={project} />)}
      </div>
    </section>

    <section class="section" aria-labelledby="posts-heading">
      <div class="section-head">
        <h2 id="posts-heading">Recent Posts</h2>
        <a class="section-link mono" href="/blog">All posts →</a>
      </div>

      <div class="post-list">
        {
          recentPosts.map((post) => (
            <article class="blog-card">
              <div class="blog-meta mono">
                <time datetime={post.date}>{fmtDate(post.date)}</time>
              </div>
              <h3>
                <a href={post.slug}>{post.title}</a>
              </h3>
              <p class="card-desc">{post.excerpt}</p>
              <a class="read-more mono" href={post.slug}>
                Read more →
              </a>
            </article>
          ))
        }
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .hero {
    min-height: 62vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    gap: var(--space-md);
    padding-block: var(--space-2xl) var(--space-xl);
  }

  .eyebrow {
    color: var(--color-accent);
    font-size: 0.9rem;
    letter-spacing: 0.04em;
    margin-bottom: var(--space-xs);
  }

  h1 {
    background: linear-gradient(120deg, var(--color-text) 30%, var(--color-accent) 120%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .tagline {
    font-size: clamp(1.1rem, 2.5vw, 1.4rem);
    color: var(--color-text-muted);
    max-width: 42ch;
    line-height: 1.5;
  }

  .accent {
    color: var(--color-accent);
    font-weight: 500;
  }

  .stack {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    margin-block: var(--space-xs);
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-top: var(--space-xs);
  }
</style>
