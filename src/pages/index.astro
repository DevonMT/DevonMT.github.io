  }

  /* ── Now ────────────────────────────────────────────────────────── */
  .now-panel {
    border-radius: 16px;
    background: linear-gradient(135deg, #0e1424, #0c1120);
    border: 1px solid rgba(255, 255, 255, 0.08);
    padding: 38px 40px;
