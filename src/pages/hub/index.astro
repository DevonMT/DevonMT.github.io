---
import PrivateLayout from '../../layouts/PrivateLayout.astro';
---

<PrivateLayout
  title="Hub — Devon Troedel"
  description="Private hub."
  label="hub"
  table="private_apps"
  intro="Enter your access key to unlock the hub."
>
  <div id="hub" hidden>
    <div class="page-bar">
      <span class="page-tag">// hub</span>
    </div>

    <main class="hub-wrap">
      <div class="hub-head">
        <div class="eyebrow">// private apps</div>
        <p class="hub-sub">Your key is saved on this device. Tap any app to open it.</p>
      </div>

      <div class="app-grid">
        <div class="app-card">
          <a href="/learn" class="card-primary-link" aria-label="Open Learning Tracker"></a>
          <div class="app-icon">📚</div>
          <div class="app-body">
            <div class="app-name">Learning Tracker</div>
            <div class="app-desc">Log sessions across books, DataCamp, and DataExpert. Track streaks, skill coverage, and weekly goals.</div>
            <div class="app-tags">
              <span class="tag">Books</span>
              <span class="tag">DataCamp</span>
              <span class="tag">DataExpert</span>
            </div>
            <div class="app-links">
              <a href="/learn#log" class="app-link">→ Log a session</a>
              <a href="/learn#dash" class="app-link">→ Dashboard</a>
            </div>
          </div>
        </div>

        <div class="app-card">
          <a href="/games" class="card-primary-link" aria-label="Open Games Dashboard"></a>
          <div class="app-icon">🎮</div>
          <div class="app-body">
            <div class="app-name">Games Dashboard</div>
            <div class="app-desc">Claude-powered recommendations from your Steam library, upcoming releases browser, and game lookup.</div>
            <div class="app-tags">
              <span class="tag">Steam</span>
              <span class="tag">RAWG</span>
              <span class="tag">Claude</span>
            </div>
            <div class="app-links">
              <a href="/games#own" class="app-link">→ My backlog</a>
              <a href="/games#discover" class="app-link">→ Discover</a>
              <a href="/games#lookup" class="app-link">→ Lookup</a>
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>
</PrivateLayout>

<style>
  /* ── Page bar ── */
  .page-bar { display: flex; align-items: center; justify-content: space-between; padding: 0.55rem 1.25rem; border-bottom: 1px solid var(--color-border); }
  .page-tag { font-family: var(--font-mono); font-size: 0.8rem; color: var(--color-accent); opacity: 0.8; }

  /* ── Hub content ── */
  .hub-wrap { max-width: 640px; margin: 0 auto; padding: 2.5rem 1.5rem 4rem; }
  .hub-head { margin-bottom: 2rem; }
  .eyebrow { font-family: var(--font-mono); font-size: 0.75rem; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.5rem; }
  .hub-sub { font-size: 0.9rem; color: var(--color-text-muted); }

  /* ── App grid ── */
  .app-grid { display: flex; flex-direction: column; gap: 0.75rem; }
  .app-card {
    display: flex; align-items: flex-start; gap: 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1.25rem 1.25rem 1.25rem 1rem;
    text-decoration: none; color: inherit;
    transition: border-color var(--transition), background var(--transition);
    position: relative;
    cursor: pointer;
  }
  .app-card:hover { border-color: var(--color-accent); background: var(--color-bg-elevated); }
  .card-primary-link { position: absolute; inset: 0; z-index: 0; border-radius: var(--radius); }
  .app-icon { font-size: 1.75rem; flex-shrink: 0; margin-top: 0.1rem; }
  .app-body { flex: 1; min-width: 0; }
  .app-name { font-family: var(--font-display); font-size: 1rem; font-weight: 600; margin-bottom: 0.4rem; }
  .app-desc { font-size: 0.85rem; color: var(--color-text-muted); line-height: 1.5; margin-bottom: 0.75rem; }
  .app-tags { display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .tag { font-family: var(--font-mono); font-size: 0.7rem; padding: 0.2rem 0.5rem; border-radius: 4px; background: var(--color-accent-soft); color: var(--color-accent); }
  .app-links { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 0.85rem; position: relative; z-index: 1; }
  .app-link { font-family: var(--font-mono); font-size: 0.78rem; color: var(--color-accent); text-decoration: none; padding: 0.3rem 0.6rem; border: 1px solid var(--color-accent); border-radius: var(--radius-xs); transition: background var(--transition); }
  .app-link:hover { background: var(--color-accent-soft); }
</style>

<script>
  // The gate (in PrivateLayout) owns auth and announces readiness via `gate:authed`.
  const hubEl = document.getElementById('hub')!;
  const reveal = () => { hubEl.hidden = false; };
  document.addEventListener('gate:authed', reveal);
  document.addEventListener('gate:locked', () => { hubEl.hidden = true; });
  // Cover the case where the gate already authed before this listener attached.
  if (document.documentElement.hasAttribute('data-authed')) reveal();
</script>
