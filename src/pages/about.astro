---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const email = 'devon.troedel@gmail.com';
const githubPro = 'https://github.com/DevonMT';
const githubLab = 'https://github.com/ArcheKnight';
const linkedin = 'https://www.linkedin.com/in/dtroedel';

const skills = [
  'SQL', 'Python', 'Power BI', 'Crystal Reports',
  'Microsoft Report Builder', 'Excel VBA', 'ETL',
  'Data Visualization', 'Streamlit', 'SQLite',
  'Process Automation', 'Flask', 'JavaScript', 'HTML/CSS',
];

const experience = [
  {
    title: 'Jr. Data Engineer',
    company: 'Walton Arts Center',
    period: 'March 2025 — Present',
  },
  {
    title: 'Software Engineer — Reports',
    company: 'ADP',
    period: 'January 2022 — March 2025',
  },
  {
    title: 'Consultant',
    company: 'ADP',
    period: 'May 2019 — January 2022',
  },
  {
    title: 'Resolution Specialist II',
    company: 'Walmart',
    period: 'July 2017 — May 2019',
  },
];
---

<BaseLayout
  title="About — Devon Troedel"
  description="Devon Troedel is a data engineer and BI analyst with 5+ years of experience in SQL, Python, Power BI, and report development. Based in Gravette, AR."
>
  <Header />
  <main>
    <section class="about">
      <p class="eyebrow mono">// about</p>
      <h1>About</h1>

      <div class="prose">
        <p>
          Hey, I'm Devon. I'm a data engineer and BI analyst living in Gravette, Arkansas,
          and I spend most of my time convincing data to behave — pipelines, dashboards,
          automation scripts, the occasional report that somebody actually wants to open.
        </p>
        <p>
          My career path goes: <span class="accent">Walmart</span> (where I discovered that
          VBA macros and a scrappy internal website could save a team hours every week) →
          <span class="accent">ADP</span> as a consultant helping enterprise clients squeeze
          more out of their workforce software → building production reports with SQL,
          Crystal Reports, and Power BI as a Software Engineer. These days I'm a Jr. Data
          Engineer at the <span class="accent">Walton Arts Center</span>, which turns out to
          be a genuinely fun place to apply the data engineering toolkit.
        </p>
        <p>
          Outside of work I build things for myself: a finance dashboard that pulls my bank
          data through Plaid and refuses to send it anywhere, CLI tools for interrogating
          CSV files, anything that scratches an itch. I have a B.S. in Mathematics from
          Arkansas Tech, two GitHub profiles (one polished, one a little chaotic), and a
          domain called <span class="accent">devondoes.dev</span> that really commits to a
          bit.
        </p>
      </div>

      <section class="exp-section">
        <h2>Experience</h2>
        <ul class="exp-list">
          {experience.map((job) => (
            <li class="exp-item">
              <div class="exp-main">
                <span class="exp-title">{job.title}</span>
                <span class="exp-company accent">{job.company}</span>
              </div>
              <span class="exp-period mono">{job.period}</span>
            </li>
          ))}
        </ul>
      </section>

      <section class="skills-section">
        <h2>Skills &amp; Tools</h2>
        <ul class="stack" aria-label="Skills and tools">
          {skills.map((skill) => <li class="tag">{skill}</li>)}
        </ul>
      </section>

      <div class="actions">
        <a class="btn btn-primary" href={linkedin} target="_blank" rel="noopener noreferrer">
          LinkedIn ↗
        </a>
        <a class="btn" href={githubPro} target="_blank" rel="noopener noreferrer">
          GitHub ↗
        </a>
        <a class="btn" href={githubLab} target="_blank" rel="noopener noreferrer">
          GitHub (lab) ↗
        </a>
        <a class="btn" href={`mailto:${email}`}>Get in touch</a>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .about {
    padding-block: var(--space-xl);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-lg);
  }

  .eyebrow {
    color: var(--color-accent);
    font-size: 0.9rem;
    letter-spacing: 0.04em;
    margin-bottom: calc(var(--space-xs) * -1);
  }

  .prose {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    max-width: 62ch;
  }
  .prose p {
    color: var(--color-text-muted);
    font-size: 1.05rem;
    line-height: 1.8;
  }
  .accent {
    color: var(--color-accent);
    font-weight: 500;
  }

  .exp-section h2,
  .skills-section h2 {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    font-weight: 600;
    margin-bottom: var(--space-sm);
  }

  .exp-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .exp-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    flex-wrap: wrap;
    padding: var(--space-sm) var(--space-md);
    border-bottom: 1px solid var(--color-border);
    background: var(--color-bg-elevated);
  }
  .exp-item:last-child {
    border-bottom: none;
  }
  .exp-main {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .exp-title {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--color-text);
  }
  .exp-company {
    font-size: 0.85rem;
  }
  .exp-period {
    font-size: 0.8rem;
    color: var(--color-text-faint);
    white-space: nowrap;
  }

  .stack {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }
</style>
