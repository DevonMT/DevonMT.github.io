---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';

const skills = [
  'SQL', 'Python', 'Snowflake', 'Power BI', 'Crystal Reports',
  'Microsoft Report Builder', 'Excel VBA', 'ETL', 'Data Visualization',
  'Streamlit', 'SQLite', 'Process Automation', 'Flask', 'JavaScript', 'HTML / CSS',
];

const experience = [
  {
    title: 'Jr. Data Engineer',
    company: 'Walton Arts Center & Walmart AMP',
    period: 'February 2026 — Present',
    current: true,
  },
  {
    title: 'Software Engineer — Reports',
    company: 'ADP',
    period: 'January 2022 — March 2025',
    current: false,
  },
  {
    title: 'Consultant',
    company: 'WorkForce Software',
    period: 'May 2019 — January 2022',
    current: false,
  },
  {
    title: 'Resolution Specialist II',
    company: 'Walmart',
    period: 'July 2017 — May 2019',
    current: false,
  },
];
---

<BaseLayout
  title="About — Devon Troedel"
  description="Devon Troedel is a data engineer and BI analyst with 5+ years of experience in SQL, Python, Power BI, and report development. Based in Gravette, AR."
>
  <div id="site">
    <div id="bg-grid" aria-hidden="true"></div>
    <SiteNav />
    <div class="page-content">

      <!-- Intro -->
      <div class="page-head">
        <div class="eyebrow-amber">01 / ABOUT</div>
      </div>

      <div class="about-grid">
        <h1 class="about-h1">
          Most of my job is making data behave. The rest is convincing it that it wants to.
        </h1>
        <div class="about-right">
          <p>
            I'm a Jr. Data Engineer at the Walton Arts Center &amp; Walmart AMP in Gravette, AR,
            where I'm building a Snowflake data warehouse from the ground up. Before that: five-plus
            years of SQL, Crystal Reports, Power BI, Python, and ETL — the unglamorous plumbing
            that makes a dashboard trustworthy.
          </p>
          <p>
            My path goes: <span class="ac">Walmart</span> (where VBA macros and a scrappy internal
            website saved the team hours every week) → <span class="ac">WorkForce Software</span> as
            a consultant helping enterprise clients squeeze more out of their workforce platform →
            building production reports with SQL, Crystal Reports, and Power BI at
            <span class="ac">ADP</span>.
          </p>
          <p>
            Outside work I build things for myself: a finance dashboard that pulls bank data through
            Plaid and refuses to send it anywhere, a Claude-powered games recommender, and whatever
            other weekend project has currently gotten a little out of hand. I have a B.S. in
            Mathematics from Arkansas Tech and two GitHub profiles — one polished, one a little chaotic.
          </p>
          <div class="skill-chips" aria-label="Skills and tools">
            {skills.map((s) => <span class="chip">{s}</span>)}
          </div>
        </div>
      </div>

      <!-- Experience -->
      <section class="section" aria-labelledby="exp-heading">
        <div class="section-eyebrow">// experience</div>
        <h2 id="exp-heading" class="section-h2">Where I've been</h2>
        <div class="exp-list" role="list">
          {experience.map((job) => (
            <div class="exp-row" role="listitem">
              <div class="exp-left">
                <span class="exp-dot" style={job.current ? 'background:#2dd4bf;box-shadow:0 0 8px rgba(45,212,191,0.7)' : 'background:#616d8c'} aria-hidden="true"></span>
                <div class="exp-info">
                  <span class="exp-title">{job.title}</span>
                  <span class="exp-company">{job.company}</span>
                </div>
              </div>
              <span class="exp-period">{job.period}</span>
            </div>
          ))}
          <div class="exp-row" role="listitem">
            <div class="exp-left">
              <span class="exp-dot" style="background:#616d8c" aria-hidden="true"></span>
              <div class="exp-info">
                <span class="exp-title">B.S. Mathematics</span>
                <span class="exp-company">Arkansas Tech University</span>
              </div>
            </div>
            <span class="exp-period">2009 — 2014</span>
          </div>
        </div>
      </section>

      <!-- Links -->
      <section class="section links-section" aria-label="Links">
        <div class="section-eyebrow">// elsewhere</div>
        <div class="action-links">
          <a href="https://linkedin.com/in/dtroedel" target="_blank" rel="noopener noreferrer" class="action-btn action-btn-primary">
            LinkedIn ↗
          </a>
          <a href="https://github.com/DevonMT" target="_blank" rel="noopener noreferrer" class="action-btn">
            GitHub · DevonMT ↗
          </a>
          <a href="https://github.com/ArcheKnight" target="_blank" rel="noopener noreferrer" class="action-btn action-btn-amber">
            GitHub · ArcheKnight ↗
          </a>
          <a href="mailto:devon.troedel@gmail.com" class="action-btn">
            Email
          </a>
        </div>
      </section>

      <SiteFooter />
    </div>
  </div>
</BaseLayout>

<style>
  #site {
    --ac: #2dd4bf;
    --ac-lite: #5fe6d4;
    --ac-soft: #7ee0d0;
    position: relative;
    min-height: 100vh;
    background:
      radial-gradient(900px 480px at 78% -8%, color-mix(in srgb, var(--ac) 10%, transparent), transparent 60%),
      radial-gradient(700px 420px at 8% 8%, rgba(240, 168, 104, 0.06), transparent 60%),
      #0a0e1a;
    overflow-x: hidden;
  }

  #bg-grid {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    opacity: 0.5;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.022) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.022) 1px, transparent 1px);
    background-size: 64px 64px;
  }

  .page-content {
    position: relative;
    z-index: 1;
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 28px;
  }

  .page-head {
    padding-top: 60px;
    margin-bottom: 32px;
  }

  .eyebrow-amber {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12.5px;
    color: #f0a868;
    letter-spacing: 0.08em;
  }

  /* About 2-col */
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 52px;
    align-items: start;
    padding-bottom: 72px;
  }

  .about-h1 {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 600;
    font-size: 34px;
    line-height: 1.22;
    letter-spacing: -0.025em;
    margin: 0;
    color: #f4f7fd;
    background: none;
    -webkit-background-clip: unset;
    background-clip: unset;
    position: sticky;
    top: 90px;
  }

  .about-right p {
    font-size: 16px;
    line-height: 1.7;
    color: #9aa6c2;
    margin: 0 0 18px;
  }

  .about-right p:last-of-type {
    margin-bottom: 24px;
  }

  .ac {
    color: var(--ac);
    font-weight: 500;
  }

  .skill-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 4px;
  }

  .chip {
    padding: 6px 12px;
    border-radius: 7px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: #cdd5e8;
  }

  /* Sections */
  .section {
    padding: 0 0 72px;
    scroll-margin-top: 80px;
  }

  .section-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: #f0a868;
    letter-spacing: 0.08em;
    margin-bottom: 10px;
  }

  .section-h2 {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 600;
    font-size: 28px;
    letter-spacing: -0.02em;
    margin: 0 0 22px;
    color: #f4f7fd;
  }

  /* Experience list */
  .exp-list {
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 14px;
    overflow: hidden;
  }

  .exp-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    flex-wrap: wrap;
    padding: 16px 22px;
    background: #0e1424;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    transition: background 0.2s;
  }

  .exp-row:last-child {
    border-bottom: none;
  }

  .exp-row:hover {
    background: #111827;
  }

  .exp-left {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .exp-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
    display: block;
  }

  .exp-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .exp-title {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 600;
    font-size: 15px;
    color: #f4f7fd;
  }

  .exp-company {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: var(--ac);
  }

  .exp-period {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11.5px;
    color: #616d8c;
    white-space: nowrap;
  }

  /* Links */
  .links-section {
    padding-bottom: 0;
  }

  .action-links {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .action-btn {
    display: inline-flex;
    align-items: center;
    padding: 11px 20px;
    border-radius: 10px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: #0e1424;
    color: #cdd5e8;
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    font-weight: 500;
    text-decoration: none;
    transition: border-color 0.2s, color 0.2s, transform 0.2s;
  }

  .action-btn:hover {
    border-color: color-mix(in srgb, var(--ac) 50%, transparent);
    color: #fff;
    transform: translateY(-2px);
  }

  .action-btn-primary {
    background: var(--ac);
    color: #0a0e1a;
    border-color: transparent;
    font-weight: 600;
  }

  .action-btn-primary:hover {
    background: var(--ac-lite);
    color: #0a0e1a;
    border-color: transparent;
  }

  .action-btn-amber {
    color: #f0a868;
    border-color: rgba(240, 168, 104, 0.25);
  }

  .action-btn-amber:hover {
    border-color: rgba(240, 168, 104, 0.6);
    color: #f0a868;
  }

  /* Responsive */
  @media (max-width: 720px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: 30px;
    }
    .about-h1 {
      position: static;
      font-size: 26px;
    }
  }
</style>
