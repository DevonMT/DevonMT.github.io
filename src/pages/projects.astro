---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { projects } from '../data/projects';
---

<BaseLayout
  title="Projects — Devon Troedel"
  description="Projects by Devon Troedel — from a privacy-first Plaid finance dashboard to Node.js web apps and work-automation tooling."
>
  <div id="site">
    <div id="bg-grid" aria-hidden="true"></div>
    <SiteNav />
    <div class="page-content">

      <div class="page-head">
        <div class="eyebrow-amber">02 / PROJECTS</div>
        <h1 class="page-h1">Weekend projects that got a little out of hand</h1>
        <p class="page-intro">Practical software I've shipped — personal tools, web apps, and the automation that quietly keeps real work systems moving.</p>
      </div>

      <div class="projects-grid">
        {projects.map((project) => <ProjectCard project={project} />)}
      </div>

      <SiteFooter />
    </div>
  </div>
</BaseLayout>

<style>
  #site {
    --ac: #2dd4bf;
    --ac-lite: #5fe6d4;
    --ac-soft: #7ee0d0;
    position: relative;
    min-height: 100vh;
    background:
      radial-gradient(900px 480px at 78% -8%, color-mix(in srgb, var(--ac) 10%, transparent), transparent 60%),
      radial-gradient(700px 420px at 8% 8%, rgba(240, 168, 104, 0.06), transparent 60%),
      #0a0e1a;
    overflow-x: clip; /* `clip` keeps the sticky nav working; `hidden` would break it */
  }

  #bg-grid {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    opacity: 0.5;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.022) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.022) 1px, transparent 1px);
    background-size: 64px 64px;
  }

  .page-content {
    position: relative;
    z-index: 1;
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 28px;
  }

  .page-head {
    padding: 60px 0 36px;
  }

  .eyebrow-amber {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12.5px;
    color: #f0a868;
    letter-spacing: 0.08em;
    margin-bottom: 18px;
  }

  .page-h1 {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 44px;
    letter-spacing: -0.03em;
    line-height: 1.05;
    color: #f4f7fd;
    margin: 0 0 14px;
    background: none;
    -webkit-background-clip: unset;
    background-clip: unset;
    max-width: 820px;
  }

  .page-intro {
    font-size: 17px;
    line-height: 1.6;
    color: #9aa6c2;
    max-width: 560px;
    margin: 0;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }

  @media (max-width: 900px) {
    .projects-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 580px) {
    .projects-grid { grid-template-columns: 1fr; }
    .page-h1 { font-size: 32px; }
  }
</style>
