    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: #3a4260;
  }

  .footer-fk-phase {
    color: #2a3050;
    font-size: 10px;
  }

  .footer-link {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: #3a4260;
    text-decoration: none;
    transition: color 0.15s;
  }
  .footer-link:hover { color: #9aa6c2; }

  /* ── Keyframes ── */
  @keyframes g-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.45; transform: scale(0.82); }
  }

  @media (prefers-reduced-motion: reduce) {
    .logo-dot, .mode-dot { animation: none; }
  }
</style>

<script>
  // ── Config ─────────────────────────────────────────────────────────────────
  // Playfinder backend (Railway). Must include the https:// scheme.
  const API_BASE = 'https://playfinder-backend-production.up.railway.app';

  // ── Storage ────────────────────────────────────────────────────────────────
  const PROFILE_KEY = 'playfinder_profile_v1';
  // Phase 3: FRIEND_KEY_SESSION = sessionStorage key for friend key
  // const FRIEND_KEY_SESSION = 'playfinder_friend_key';

  // ── Slider defaults ────────────────────────────────────────────────────────
  const SLIDER_DEFAULTS: Record<string, number> = {
    pacing: 50,
    difficulty: 50,
    storyVsSystems: 50,
    tone: 50,
  };

  // ── Chip option definitions ────────────────────────────────────────────────
  interface ChipOption { value: string; label: string; }

  const SESSION_LENGTH_OPTS: ChipOption[] = [
    { value: 'quick',  label: '15–30 min' },
    { value: 'medium', label: '1–2 hr' },
    { value: 'long',   label: '3+ hr marathons' },
    { value: 'varies', label: 'varies' },
  ];

  const MULTIPLAYER_OPTS: ChipOption[] = [
    { value: 'single', label: 'solo' },
    { value: 'coop',   label: 'co-op' },
    { value: 'pvp',    label: 'competitive' },
    { value: 'mix',    label: 'either works' },
  ];

  const SETTINGS_OPTS: ChipOption[] = [
    { value: 'fantasy',          label: 'fantasy' },
    { value: 'sci-fi',           label: 'sci-fi' },
    { value: 'historical',       label: 'historical' },
    { value: 'modern',           label: 'modern' },
    { value: 'post-apocalyptic', label: 'post-apocalyptic' },
    { value: 'horror',           label: 'horror' },
    { value: 'cyberpunk',        label: 'cyberpunk' },
    { value: 'space',            label: 'space' },
    { value: 'grounded-realistic', label: 'grounded / realistic' },
    { value: 'surreal-stylized', label: 'surreal / stylized' },
  ];

  const GENRES_OPTS: ChipOption[] = [
    { value: 'rpg',          label: 'RPG' },
    { value: 'action',       label: 'action' },
    { value: 'strategy',     label: 'strategy' },
    { value: 'shooter',      label: 'shooter' },
    { value: 'platformer',   label: 'platformer' },
    { value: 'roguelike',    label: 'roguelike' },
    { value: 'sim',          label: 'sim' },
    { value: 'survival',     label: 'survival' },
    { value: 'puzzle',       label: 'puzzle' },
    { value: 'fighting',     label: 'fighting' },
    { value: 'racing',       label: 'racing' },
    { value: 'metroidvania', label: 'metroidvania' },
    { value: 'cozy',         label: 'cozy' },
    { value: 'soulslike',    label: 'soulslike' },
  ];

  const ART_STYLE_OPTS: ChipOption[] = [
    { value: 'realistic',    label: 'realistic' },
    { value: 'stylized-3d',  label: 'stylized 3D' },
    { value: 'pixel-art',    label: 'pixel art' },
    { value: 'anime',        label: 'anime' },
    { value: 'hand-drawn',   label: 'hand-drawn' },
    { value: 'minimalist',   label: 'minimalist' },
    { value: 'retro',        label: 'retro' },
    { value: 'painterly',    label: 'painterly' },
  ];

  const COMPLETION_OPTS: ChipOption[] = [
    { value: '100%-completionist', label: '100% completionist' },
    { value: 'main-story',         label: 'main story then out' },
    { value: 'endless-replayer',   label: 'endless replayer / NG+' },
    { value: 'whatever-sticks',    label: 'whatever sticks' },
  ];

  const PLATFORM_FILTER_OPTS: ChipOption[] = [
    { value: '',              label: 'any platform' },
    { value: 'pc',            label: 'PC' },
    { value: 'playstation5',  label: 'PS5' },
    { value: 'playstation4',  label: 'PS4' },
    { value: 'xbox-series-x', label: 'Xbox' },
    { value: 'nintendo-switch', label: 'Switch' },
  ];

  // ── State ──────────────────────────────────────────────────────────────────
  // Single-select chip state keyed by fieldName → selected value
  const singleSelect: Record<string, string> = {
    sessionLength: 'varies',
    multiplayer: 'mix',
    completion: 'whatever-sticks',
    platformFilter: '',
  };

  // Multi-select chip state keyed by fieldName → Set of selected values
  const multiSelect: Record<string, Set<string>> = {
    settings: new Set(),
    genres: new Set(),
    artStyle: new Set(),
  };

  // Multi-select caps
  const MULTI_CAPS: Record<string, number> = {
    settings: 6,
    genres: 8,
    artStyle: 5,
  };

  // ── Helpers ────────────────────────────────────────────────────────────────
  function escapeHtml(s: string): string {
    const div = document.createElement('div');
    div.textContent = s ?? '';
    return div.innerHTML;
  }

  function confClass(score: number): { text: string; bg: string } {
    if (score >= 75) return { text: 'conf-high', bg: 'conf-high-bg' };
    if (score >= 50) return { text: 'conf-mid',  bg: 'conf-mid-bg' };
    return { text: 'conf-low', bg: 'conf-low-bg' };
  }

  // ── Chip builders ──────────────────────────────────────────────────────────

  /**
   * Build a set of single-select chips into a container.
   * stateKey is a key in singleSelect.
   */
  function buildSingleChips(
    container: HTMLElement,
    options: ChipOption[],
    stateKey: string,
    onChange: () => void,
  ): void {
    container.innerHTML = '';
    options.forEach(({ value, label }) => {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'chip' + (singleSelect[stateKey] === value ? ' active' : '');
      btn.textContent = label;
      btn.dataset['value'] = value;
      btn.addEventListener('click', () => {
        singleSelect[stateKey] = value;
        container.querySelectorAll<HTMLElement>('.chip').forEach((c) => {
          c.classList.toggle('active', c.dataset['value'] === value);
        });
        onChange();
      });
      container.appendChild(btn);
    });
  }

  /**
   * Build a set of multi-select chips into a container.
   * stateKey is a key in multiSelect; cap is the max selections.
   */
  function buildMultiChips(
    container: HTMLElement,
    options: ChipOption[],
    stateKey: string,
    cap: number,
    onChange: () => void,
  ): void {
    container.innerHTML = '';
    const sel = multiSelect[stateKey]!;
    options.forEach(({ value, label }) => {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'chip' + (sel.has(value) ? ' active' : '');
      btn.textContent = label;
      btn.dataset['value'] = value;
      btn.addEventListener('click', () => {
        if (sel.has(value)) {
          sel.delete(value);
          btn.classList.remove('active');
        } else if (sel.size < cap) {
          sel.add(value);
          btn.classList.add('active');
        }
        // If at cap, silently ignore (don't 400 — just don't add more).
        onChange();
      });
      container.appendChild(btn);
    });
  }

  // ── Reference game rows ────────────────────────────────────────────────────
  interface RefGameEntry { title: string; why: string; }

  let refGames: RefGameEntry[] = [{ title: '', why: '' }];

  function renderRefGames(onChange: () => void): void {
    const list = document.getElementById('ref-games-list')!;
    const addBtn = document.getElementById('add-ref-game') as HTMLButtonElement;
    list.innerHTML = '';

    refGames.forEach((entry, idx) => {
      const row = document.createElement('div');
      row.className = 'ref-game-row';

      const titleInput = document.createElement('input');
      titleInput.type = 'text';
      titleInput.className = 'ref-game-title';
      titleInput.placeholder = 'Game title';
      titleInput.value = entry.title;
      titleInput.setAttribute('aria-label', `Reference game ${idx + 1} title`);
      titleInput.addEventListener('input', () => {
        const e = refGames[idx];
        if (e) e.title = titleInput.value;
        onChange();
      });

      const whyInput = document.createElement('textarea');
      whyInput.className = 'ref-game-why';
      whyInput.placeholder = 'What specifically you loved — the combat, the story beats, the freedom, the mood…';
      whyInput.rows = 2;
      whyInput.value = entry.why;
      whyInput.setAttribute('aria-label', `Reference game ${idx + 1} why`);
      whyInput.addEventListener('input', () => {
        const e = refGames[idx];
        if (e) e.why = whyInput.value;
        onChange();
      });

      const removeBtn = document.createElement('button');
      removeBtn.type = 'button';
      removeBtn.className = 'ref-game-remove';
      removeBtn.textContent = '✕';
      removeBtn.setAttribute('aria-label', `Remove game ${idx + 1}`);
      removeBtn.disabled = refGames.length <= 1;
      if (refGames.length <= 1) removeBtn.style.opacity = '0.3';
      removeBtn.addEventListener('click', () => {
        refGames.splice(idx, 1);
        if (refGames.length === 0) refGames = [{ title: '', why: '' }];
        renderRefGames(onChange);
        onChange();
      });

      row.appendChild(titleInput);
      row.appendChild(whyInput);
      row.appendChild(removeBtn);
      list.appendChild(row);
    });

    addBtn.style.display = refGames.length >= 5 ? 'none' : '';
  }

  // ── Profile serialization ─────────────────────────────────────────────────

  function serializeProfile(): object {
    const sliders: Record<string, number> = {};
    ['pacing', 'difficulty', 'storyVsSystems', 'tone'].forEach((id) => {
      const el = document.getElementById(id) as HTMLInputElement | null;
      sliders[id] = el ? parseInt(el.value, 10) : SLIDER_DEFAULTS[id] ?? 50;
    });

    const cleanRefGames = refGames
      .filter((r) => r.title.trim() || r.why.trim())
      .map((r) => ({ title: r.title.trim(), why: r.why.trim() }));

    const notesEl = document.getElementById('notes') as HTMLTextAreaElement | null;

    return {
      v: 1,
      pacing:         sliders['pacing'] ?? 50,
      difficulty:     sliders['difficulty'] ?? 50,
      sessionLength:  singleSelect['sessionLength'] ?? 'varies',
      multiplayer:    singleSelect['multiplayer'] ?? 'mix',
      storyVsSystems: sliders['storyVsSystems'] ?? 50,
      settings:       [...(multiSelect['settings'] ?? [])],
      genres:         [...(multiSelect['genres'] ?? [])],
      tone:           sliders['tone'] ?? 50,
      artStyle:       [...(multiSelect['artStyle'] ?? [])],
      completion:     singleSelect['completion'] ?? 'whatever-sticks',
      referenceGames: cleanRefGames,
      notes:          notesEl?.value.trim() ?? '',
    };
  }

  // ── Profile strength meter ─────────────────────────────────────────────────

  function renderStrength(): void {
    const pct = document.getElementById('strength-pct')!;
    const fill = document.getElementById('strength-fill')!;
    const hint = document.getElementById('strength-hint')!;

    let points = 0;
    const max = 10;

    // Sliders touched (not at default 50)
    const sliderIds = ['pacing', 'difficulty', 'storyVsSystems', 'tone'];
    sliderIds.forEach((id) => {
      const el = document.getElementById(id) as HTMLInputElement | null;
      if (el && parseInt(el.value, 10) !== 50) points++;
    });

    // Single selects non-default
    if (singleSelect['sessionLength'] !== 'varies') points++;
    if (singleSelect['multiplayer'] !== 'mix') points++;
    if (singleSelect['completion'] !== 'whatever-sticks') points++;

    // Multi selects — 1 point if any selected
    if ((multiSelect['settings']?.size ?? 0) > 0) points++;
    if ((multiSelect['genres']?.size ?? 0) > 0) points++;
    if ((multiSelect['artStyle']?.size ?? 0) > 0) points++;

    // Bonus: reference game with a title
    const hasRef = refGames.some((r) => r.title.trim().length > 0);
    if (hasRef) points = Math.min(max, points + 1);

    const score = Math.round((points / max) * 100);
    pct.textContent = `${score}%`;
    fill.style.width = `${score}%`;

    if (score === 0) {
      hint.textContent = 'Move a slider or pick a chip to start building your profile.';
      fill.style.background = 'var(--ac)';
    } else if (score < 40) {
      hint.textContent = 'Good start — add a genre or reference game to sharpen results.';
      fill.style.background = '#f0a868';
    } else if (score < 70) {
      hint.textContent = 'Nice profile — a reference game with a "why" will boost quality a lot.';
      fill.style.background = '#f0a868';
    } else {
      hint.textContent = 'Strong profile — Claude has plenty of signal to work with.';
      fill.style.background = 'var(--ac)';
    }
  }

  // ── localStorage persistence (debounced) ──────────────────────────────────

  let saveTimer: ReturnType<typeof setTimeout> | null = null;

  function schedSave(): void {
    renderStrength();
    if (saveTimer !== null) clearTimeout(saveTimer);
    saveTimer = setTimeout(() => {
      try {
        localStorage.setItem(PROFILE_KEY, JSON.stringify(serializeProfile()));
      } catch {
        // Storage full or blocked — non-fatal.
      }
    }, 400);
  }

  function loadProfile(): void {
    try {
      const raw = localStorage.getItem(PROFILE_KEY);
      if (!raw) return;
      const p = JSON.parse(raw) as Record<string, unknown>;

      // Sliders
      const sliderIds = ['pacing', 'difficulty', 'storyVsSystems', 'tone'];
      sliderIds.forEach((id) => {
        const el = document.getElementById(id) as HTMLInputElement | null;
        if (el && typeof p[id] === 'number') el.value = String(p[id]);
      });

      // Single selects
      const singleKeys: Array<[string, string]> = [
        ['sessionLength', 'varies'],
        ['multiplayer', 'mix'],
        ['completion', 'whatever-sticks'],
      ];
      singleKeys.forEach(([key, def]) => {
        const val = typeof p[key] === 'string' ? (p[key] as string) : def;
        singleSelect[key] = val;
      });

      // Multi selects
      const multiKeys = ['settings', 'genres', 'artStyle'] as const;
      multiKeys.forEach((key) => {
        const arr = p[key];
        if (Array.isArray(arr)) {
          multiSelect[key] = new Set(arr.filter((v): v is string => typeof v === 'string'));
        }
      });

      // Reference games
      if (Array.isArray(p['referenceGames'])) {
        const loaded = (p['referenceGames'] as unknown[])
          .filter((r): r is Record<string, unknown> => typeof r === 'object' && r !== null)
          .map((r) => ({
            title: typeof r['title'] === 'string' ? r['title'] : '',
            why:   typeof r['why']   === 'string' ? r['why']   : '',
          }));
        if (loaded.length > 0) refGames = loaded;
      }

      // Notes
      const notesEl = document.getElementById('notes') as HTMLTextAreaElement | null;
      if (notesEl && typeof p['notes'] === 'string') notesEl.value = p['notes'];
    } catch {
      // Corrupt or missing — silently ignore.
    }
  }

  // ── API wrapper ────────────────────────────────────────────────────────────

  async function api(path: string, init: RequestInit = {}): Promise<unknown> {
    // Phase 3: attach x-friend-key when in friend mode
    // const friendKey = sessionStorage.getItem(FRIEND_KEY_SESSION);
    // const extraHeaders = friendKey ? { 'x-friend-key': friendKey } : {};

    const res = await fetch(`${API_BASE}${path}`, {
      ...init,
      headers: {
        'Content-Type': 'application/json',
        // ...(friendKey ? { 'x-friend-key': friendKey } : {}),
        ...(init.headers ?? {}),
      },
    });

    if (res.status === 429) {
      let retryMins = 60;
      try {
        const body = await res.json() as Record<string, unknown>;
        const secs = typeof body['retryAfterSeconds'] === 'number' ? body['retryAfterSeconds'] : 3600;
        retryMins = Math.ceil(secs / 60);
      } catch { /* ignore */ }
      throw new RateLimitError(`You've hit the free limit — try again in ~${retryMins} minute(s), or use a friend key for unlimited access.`);
    }

    if (!res.ok) {
      let msg = `Request failed (${res.status})`;
      try {
        const body = await res.json() as Record<string, unknown>;
        if (typeof body['error'] === 'string') msg = body['error'];
      } catch { /* ignore */ }
      throw new Error(msg);
    }

    return res.json();
  }

  class RateLimitError extends Error {
    constructor(message: string) {
      super(message);
      this.name = 'RateLimitError';
    }
  }

  // ── Result rendering ───────────────────────────────────────────────────────

  function renderDiscoverCard(item: {
    name: string;
    platforms: string[];
    description: string;
    confidenceScore: number;
    reasoning: string;
  }): HTMLElement {
    const card = document.createElement('article');
    card.className = 'discover-card';
    const score = Math.max(0, Math.min(100, Math.round(item.confidenceScore ?? 0)));
    const cls = confClass(score);
    const platformsText = (item.platforms ?? []).map(escapeHtml).join(' · ');

    card.innerHTML = `
      <div>
        <span class="discover-name">${escapeHtml(item.name || 'Unknown')}</span>
        ${platformsText ? `<span class="discover-platforms">${platformsText}</span>` : ''}
      </div>
      ${item.description ? `<p class="reco-text">${escapeHtml(item.description)}</p>` : ''}
      <div class="reco-head">
        <span class="reco-label">Match</span>
        <span class="reco-score ${cls.text}">${score}</span>
      </div>
      <div class="reco-bar"><span class="${cls.bg}" style="width:${score}%"></span></div>
      <p class="reco-text">${escapeHtml(item.reasoning || '')}</p>
    `;
    return card;
  }

  // ── Discover handler ───────────────────────────────────────────────────────

  async function runDiscover(): Promise<void> {
    const discoverBtn = document.getElementById('discover-btn') as HTMLButtonElement;
    const resultsSection = document.getElementById('results-section')!;
    const resultsStatus = document.getElementById('results-status')!;
    const resultsGrid = document.getElementById('results-grid')!;

    discoverBtn.disabled = true;
    discoverBtn.innerHTML = '<span class="spinner"></span> Brainstorming…';

    resultsSection.hidden = false;
    resultsStatus.className = 'grid-status';
    resultsStatus.hidden = false;
    resultsStatus.innerHTML = '<span class="spinner"></span> Asking Claude for picks…';
    resultsGrid.innerHTML = '';

    // Scroll to results
    resultsSection.scrollIntoView({ behavior: 'smooth', block: 'start' });

    const platformVal = singleSelect['platformFilter'] ?? '';
    const opts: Record<string, unknown> = {};
    if (platformVal) opts['platforms'] = [platformVal];

    try {
      const data = await api('/discover', {
        method: 'POST',
        body: JSON.stringify({ profile: serializeProfile(), opts }),
      }) as Record<string, unknown>;

      const picks = (data['picks'] as unknown[]) ?? [];

      if (picks.length === 0) {
        resultsStatus.textContent = 'No picks returned — try adjusting your taste profile.';
        resultsStatus.hidden = false;
        return;
      }

      resultsStatus.hidden = true;
      (picks as Array<{
        name: string;
        platforms: string[];
        description: string;
        confidenceScore: number;
        reasoning: string;
      }>).forEach((p) => resultsGrid.appendChild(renderDiscoverCard(p)));

    } catch (err: unknown) {
      resultsStatus.className = 'grid-status error';
      resultsStatus.hidden = false;
      if (err instanceof Error) {
        resultsStatus.textContent = err.message;
      } else {
        resultsStatus.textContent = 'Something went wrong. Try again.';
      }
    } finally {
      discoverBtn.disabled = false;
      discoverBtn.textContent = 'Brainstorm games →';
    }
  }

  // ── Init ───────────────────────────────────────────────────────────────────

  function init(): void {
    // Load saved profile first so chip builders can pick up restored state.
    loadProfile();

    // Build single-select chips
    buildSingleChips(
      document.getElementById('sessionLength-chips')!,
      SESSION_LENGTH_OPTS,
      'sessionLength',
      schedSave,
    );
    buildSingleChips(
      document.getElementById('multiplayer-chips')!,
      MULTIPLAYER_OPTS,
      'multiplayer',
      schedSave,
    );
    buildSingleChips(
      document.getElementById('completion-chips')!,
      COMPLETION_OPTS,
      'completion',
      schedSave,
    );
    buildSingleChips(
      document.getElementById('platform-filter-chips')!,
      PLATFORM_FILTER_OPTS,
      'platformFilter',
      schedSave,
    );

    // Build multi-select chips
    buildMultiChips(
      document.getElementById('settings-chips')!,
      SETTINGS_OPTS,
      'settings',
      MULTI_CAPS['settings'] ?? 6,
      schedSave,
    );
    buildMultiChips(
      document.getElementById('genres-chips')!,
      GENRES_OPTS,
      'genres',
      MULTI_CAPS['genres'] ?? 8,
      schedSave,
    );
    buildMultiChips(
      document.getElementById('artStyle-chips')!,
      ART_STYLE_OPTS,
      'artStyle',
      MULTI_CAPS['artStyle'] ?? 5,
      schedSave,
    );

    // Render ref games
    renderRefGames(schedSave);

    // Add ref game button
    document.getElementById('add-ref-game')!.addEventListener('click', () => {
      if (refGames.length < 5) {
        refGames.push({ title: '', why: '' });
        renderRefGames(schedSave);
      }
    });

    // Slider listeners
    ['pacing', 'difficulty', 'storyVsSystems', 'tone'].forEach((id) => {
      document.getElementById(id)?.addEventListener('input', schedSave);
    });

    // Notes listener
    document.getElementById('notes')?.addEventListener('input', schedSave);

    // Discover CTA — thin-profile nudge (non-blocking)
    document.getElementById('discover-btn')!.addEventListener('click', () => {
      // Check if profile is essentially empty:
      // no chips selected in any group, no ref game with title or why, all sliders at default 50
      const noChips =
        singleSelect['sessionLength'] === 'varies' &&
        singleSelect['multiplayer'] === 'mix' &&
        singleSelect['completion'] === 'whatever-sticks' &&
        (multiSelect['settings']?.size ?? 0) === 0 &&
        (multiSelect['genres']?.size ?? 0) === 0 &&
        (multiSelect['artStyle']?.size ?? 0) === 0;

      const allSlidersDefault = ['pacing', 'difficulty', 'storyVsSystems', 'tone'].every((id) => {
        const el = document.getElementById(id) as HTMLInputElement | null;
        return !el || parseInt(el.value, 10) === 50;
      });

      const noRefGame = !refGames.some((r) => r.title.trim().length > 0 || r.why.trim().length > 0);

      if (noChips && allSlidersDefault && noRefGame) {
        const hint = document.getElementById('strength-hint')!;
        hint.textContent = 'Pick a few chips or add a reference game with the why for sharper picks.';
        hint.style.color = '#f0a868';
        // Reset hint color after a few seconds so it doesn't persist as an error
        setTimeout(() => { hint.style.color = ''; renderStrength(); }, 5000);
      }

      // Always proceed — non-blocking
      runDiscover().catch(() => {});
    });

    // Initial strength render
    renderStrength();
  }

  init();
</script>
