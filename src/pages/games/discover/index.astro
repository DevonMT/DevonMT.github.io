---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SiteNav from '../../../components/SiteNav.astro';
---

<BaseLayout
  title="Game Discovery — Devon Troedel"
  description="Tell us your taste in games and get personalized recommendations, powered by Claude."
>
  <div id="site">
    <div id="bg-grid" aria-hidden="true"></div>

    <!-- ── Nav ── -->
    <SiteNav />

    <div class="page-content">

      <!-- ── Page header ── -->
      <div class="page-head">
        <div class="eyebrow-amber">// game discovery</div>
        <h1 class="page-h1">Find your next game</h1>
        <p class="page-sub">Fill in your taste profile — 20 seconds to start, 2 minutes to go deep. Claude will brainstorm picks matched specifically to you.</p>
      </div>

      <!-- ── Mode indicator ── -->
      <div id="mode-bar" class="mode-bar">
        <span class="mode-dot" aria-hidden="true"></span>
        <span id="mode-label" class="mode-label">Public mode — profile saved to this browser</span>
      </div>

      <!-- ── Taste profile questionnaire ── -->
      <form id="profile-form" novalidate>

        <!-- ── Section 1: // how you play ── -->
        <div class="section-card">
          <div class="section-eyebrow">// how you play</div>

          <!-- Pacing -->
          <div class="field">
            <label class="field-label" for="pacing">Pacing</label>
            <input type="range" id="pacing" name="pacing" min="0" max="100" value="50" class="slider" />
            <div class="slider-ends">
              <span class="slider-end-l">Methodical / tactical</span>
              <span class="slider-end-r">Fast-twitch / reflexes</span>
            </div>
          </div>

          <!-- Difficulty -->
          <div class="field">
            <label class="field-label" for="difficulty">Difficulty tolerance</label>
            <input type="range" id="difficulty" name="difficulty" min="0" max="100" value="50" class="slider" />
            <div class="slider-ends">
              <span class="slider-end-l">Relaxing / forgiving</span>
              <span class="slider-end-r">Punishing / I want to suffer</span>
            </div>
          </div>

          <!-- Session length -->
          <div class="field">
            <span class="field-label">Typical session length</span>
            <div class="chip-row" id="sessionLength-chips" role="group" aria-label="Typical session length"></div>
          </div>

          <!-- Multiplayer -->
          <div class="field">
            <span class="field-label">Players</span>
            <div class="chip-row" id="multiplayer-chips" role="group" aria-label="Players"></div>
          </div>
        </div>

        <!-- ── Section 2: // what you're into ── -->
        <div class="section-card">
          <div class="section-eyebrow">// what you're into</div>

          <!-- Story vs. systems -->
          <div class="field">
            <label class="field-label" for="storyVsSystems">Story vs. systems</label>
            <input type="range" id="storyVsSystems" name="storyVsSystems" min="0" max="100" value="50" class="slider" />
            <div class="slider-ends">
              <span class="slider-end-l">All about story &amp; characters</span>
              <span class="slider-end-r">All about mechanics &amp; systems</span>
            </div>
          </div>

          <!-- Settings -->
          <div class="field">
            <span class="field-label">Settings <span class="field-cap">(pick up to 6)</span></span>
            <div class="chip-row" id="settings-chips" role="group" aria-label="Settings"></div>
          </div>

          <!-- Genres -->
          <div class="field">
            <span class="field-label">Genres you gravitate to <span class="field-cap">(pick up to 8)</span></span>
            <div class="chip-row" id="genres-chips" role="group" aria-label="Genres"></div>
          </div>
        </div>

        <!-- ── Section 3: // the vibe ── -->
        <div class="section-card">
          <div class="section-eyebrow">// the vibe</div>

          <!-- Tone -->
          <div class="field">
            <label class="field-label" for="tone">Tone / atmosphere</label>
            <input type="range" id="tone" name="tone" min="0" max="100" value="50" class="slider" />
            <div class="slider-ends">
              <span class="slider-end-l">Lighthearted / cozy / funny</span>
              <span class="slider-end-r">Dark / gritty / serious</span>
            </div>
          </div>

          <!-- Art style -->
          <div class="field">
            <span class="field-label">Art-style leanings <span class="field-cap">(pick up to 5)</span></span>
            <div class="chip-row" id="artStyle-chips" role="group" aria-label="Art style"></div>
          </div>

          <!-- Completion style -->
          <div class="field">
            <span class="field-label">Completion style</span>
            <div class="chip-row" id="completion-chips" role="group" aria-label="Completion style"></div>
          </div>
        </div>

        <!-- ── Section 4: // your north stars ── -->
        <div class="section-card">
          <div class="section-eyebrow">// your north stars</div>
          <p class="section-hint">Highest-signal section. The "why" is more useful than the title — it tells Claude <em>which axis</em> of a game to match on.</p>

          <!-- Reference games -->
          <div class="field" id="ref-games-field">
            <span class="field-label">Reference games + why you loved them</span>
            <div id="ref-games-list"></div>
            <button type="button" id="add-ref-game" class="btn-secondary btn-sm add-ref-btn">+ add another game</button>
          </div>

          <!-- Notes -->
          <div class="field">
            <label class="field-label" for="notes">Anything else</label>
            <p class="field-hint">Dealbreakers, things you're sick of, mood right now, hardware constraints.</p>
            <textarea id="notes" name="notes" class="g-textarea" rows="3" placeholder="e.g. PC only. Sick of live-service grinds. Want something I can finish."></textarea>
          </div>
        </div>

        <!-- ── Profile strength meter ── -->
        <div class="strength-bar-wrap">
          <div class="strength-label-row">
            <span class="field-label">Profile strength</span>
            <span id="strength-pct" class="strength-pct">0%</span>
          </div>
          <div class="strength-track">
            <div id="strength-fill" class="strength-fill"></div>
          </div>
          <p id="strength-hint" class="strength-hint">Move a slider or pick a chip to start building your profile.</p>
        </div>

        <!-- ── Sticky CTA ── -->
        <div class="sticky-cta">
          <div class="sticky-cta-inner">
            <button type="button" id="discover-btn" class="btn-primary">
              Brainstorm games →
            </button>
            <div class="cta-opts">
              <div class="filter-group">
                <span class="field-label">Platform</span>
                <div class="chip-row" id="platform-filter-chips" role="group" aria-label="Platform filter"></div>
              </div>
            </div>
          </div>
        </div>

      </form><!-- #profile-form -->

      <!-- ── Results ── -->
      <section id="results-section" hidden>
        <div class="results-head">
          <div class="eyebrow-amber">// brainstorm results</div>
          <h2 class="results-h2">Games you might love</h2>
        </div>
        <p id="results-status" class="grid-status" hidden></p>
        <div id="results-grid" class="result-grid"></div>
      </section>

    </div><!-- .page-content -->

    <!-- ── Footer ── -->
    <footer class="site-footer">
      <div class="footer-inner">
        <span class="footer-copy">&copy; 2026 Devon Troedel</span>

        <!--
          PHASE 3 PLACEHOLDER — friend-key footer affordance
          When Phase 3 ships, this area gets an expandable "// friend key" input
          that: accepts the key → switches mode to 'friend' → stores in sessionStorage
          → migrates any existing localStorage profile to the server (PUT /profile)
          → loads the server profile on subsequent visits.
          For now, only the structural placeholder lives here.
        -->
        <div id="friend-key-footer" class="friend-key-footer" aria-label="Friend key (Phase 3)">
          <!-- Phase 3: expand button + key input will go here -->
          <span class="footer-fk-note">// friend key <span class="footer-fk-phase">(coming soon)</span></span>
        </div>

        <a href="/games" class="footer-link">← games dashboard</a>
      </div>
    </footer>

  </div><!-- #site -->
</BaseLayout>

<!-- Global styles: dynamically-created elements need global scope -->
<style is:global>
  /* ── Chips (built by buildChips()) ── */
  .chip {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: #9aa6c2;
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    padding: 6px 13px;
    cursor: pointer;
    transition: color 0.15s, background 0.15s, border-color 0.15s;
    user-select: none;
  }
  .chip:hover {
    color: #e9edf7;
    border-color: rgba(255, 255, 255, 0.2);
  }
  .chip.active {
    color: #2dd4bf;
    background: color-mix(in srgb, #2dd4bf 10%, transparent);
    border-color: color-mix(in srgb, #2dd4bf 40%, transparent);
    font-weight: 600;
  }

  /* ── Discover result cards ── */
  .discover-card {
    background: #0e1424;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 14px;
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    transition: border-color 0.2s, transform 0.2s;
  }
  .discover-card:hover {
    border-color: color-mix(in srgb, #2dd4bf 35%, transparent);
    transform: translateY(-3px);
  }
  .discover-name {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 16px;
    font-weight: 600;
    color: #f4f7fd;
    display: block;
  }
  .discover-platforms {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: #616d8c;
    display: block;
    margin-top: 3px;
  }

  /* ── Confidence bar components ── */
  .reco-head {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .reco-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: #616d8c;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .reco-score {
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    font-weight: 700;
  }
  .reco-bar {
    height: 5px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.06);
    overflow: hidden;
  }
  .reco-bar > span {
    display: block;
    height: 100%;
    border-radius: 999px;
    transition: width 0.4s ease;
  }
  .conf-high    { color: #2dd4bf; }
  .conf-high-bg { background: #2dd4bf; }
  .conf-mid     { color: #f0a868; }
  .conf-mid-bg  { background: #f0a868; }
  .conf-low     { color: #9aa6c2; }
  .conf-low-bg  { background: #9aa6c2; }
  .reco-text  { font-size: 13.5px; color: #9aa6c2; line-height: 1.55; margin: 0; }
  .reco-error { font-size: 13.5px; color: #f87171; margin: 0; }

  /* ── Spinner ── */
  .spinner {
    display: inline-block;
    width: 0.85em;
    height: 0.85em;
    border: 2px solid currentColor;
    border-right-color: transparent;
    border-radius: 50%;
    animation: g-spin 0.6s linear infinite;
    vertical-align: -0.1em;
  }
  @keyframes g-spin { to { transform: rotate(360deg); } }
  button[disabled] { opacity: 0.55; cursor: progress; }

  /* ── Reference game rows (built by JS) ── */
  .ref-game-row {
    display: grid;
    grid-template-columns: 1fr 2fr auto;
    gap: 10px;
    align-items: start;
    margin-bottom: 10px;
  }
  @media (max-width: 640px) {
    .ref-game-row { grid-template-columns: 1fr; }
  }
  .ref-game-title {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 9px;
    color: #e9edf7;
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    padding: 9px 13px;
    transition: border-color 0.2s;
    width: 100%;
    box-sizing: border-box;
  }
  .ref-game-title:focus {
    outline: none;
    border-color: color-mix(in srgb, #2dd4bf 60%, transparent);
  }
  .ref-game-why {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 9px;
    color: #e9edf7;
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    padding: 9px 13px;
    resize: vertical;
    line-height: 1.5;
    min-height: 70px;
    transition: border-color 0.2s;
    width: 100%;
    box-sizing: border-box;
  }
  .ref-game-why:focus {
    outline: none;
    border-color: color-mix(in srgb, #2dd4bf 60%, transparent);
  }
  .ref-game-remove {
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 7px;
    color: #616d8c;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    padding: 6px 10px;
    cursor: pointer;
    white-space: nowrap;
    transition: color 0.15s, border-color 0.15s;
    margin-top: 2px;
  }
  .ref-game-remove:hover { color: #f87171; border-color: #f87171; }
</style>

<style>
  /* ── Site shell ── */
  #site {
    --ac: #2dd4bf;
    --ac-lite: #5fe6d4;
    --ac-soft: #7ee0d0;
    position: relative;
    min-height: 100vh;
    background:
      radial-gradient(900px 480px at 78% -8%, color-mix(in srgb, var(--ac) 10%, transparent), transparent 60%),
      radial-gradient(700px 420px at 8% 8%, rgba(240, 168, 104, 0.06), transparent 60%),
      #0a0e1a;
    overflow-x: clip; /* `clip` keeps the sticky nav + sticky CTA working; `hidden` would break them */
  }

  #bg-grid {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    opacity: 0.5;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.022) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.022) 1px, transparent 1px);
    background-size: 64px 64px;
  }

  /* ── Page content ── */
  .page-content {
    position: relative;
    z-index: 1;
    max-width: 860px;
    margin: 0 auto;
    padding: 0 28px 120px;
  }

  /* ── Page header ── */
  .page-head {
    padding: 52px 0 32px;
  }

  .eyebrow-amber {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12.5px;
    color: #f0a868;
    letter-spacing: 0.08em;
    margin-bottom: 14px;
  }

  .page-h1 {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 48px;
    letter-spacing: -0.03em;
    line-height: 1;
    color: #f4f7fd;
    margin: 0 0 16px;
  }

  .page-sub {
    font-size: 16px;
    color: #9aa6c2;
    line-height: 1.6;
    margin: 0;
    max-width: 600px;
  }

  /* ── Mode bar ── */
  .mode-bar {
    display: flex;
    align-items: center;
    gap: 10px;
    background: #0e1424;
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 10px;
    padding: 10px 16px;
    margin-bottom: 24px;
  }

  .mode-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--ac);
    box-shadow: 0 0 8px color-mix(in srgb, var(--ac) 70%, transparent);
    animation: g-pulse 2.4s ease-in-out infinite;
    flex-shrink: 0;
  }

  .mode-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: #9aa6c2;
  }

  /* ── Section cards ── */
  .section-card {
    background: #0e1424;
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 14px;
    padding: 24px;
    margin-bottom: 16px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .section-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: #f0a868;
    letter-spacing: 0.08em;
    margin-bottom: -4px;
  }

  .section-hint {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: #616d8c;
    line-height: 1.6;
    margin: -8px 0 0;
  }
  .section-hint em { color: #9aa6c2; font-style: normal; }

  /* ── Fields ── */
  .field {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .field-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11.5px;
    color: #616d8c;
    text-transform: uppercase;
    letter-spacing: 0.07em;
  }

  .field-cap {
    font-weight: 400;
    text-transform: none;
    letter-spacing: 0;
    color: #4a5470;
    font-size: 10.5px;
  }

  .field-hint {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11.5px;
    color: #4a5470;
    margin: -4px 0 0;
    line-height: 1.5;
  }

  /* ── Sliders ── */
  .slider-ends {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    margin-top: 6px;
  }

  .slider-end-l {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10.5px;
    color: #4a5470;
    text-align: left;
  }

  .slider-end-r {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10.5px;
    color: #4a5470;
    text-align: right;
  }

  .slider {
    -webkit-appearance: none;
    appearance: none;
    width: 100%;
    height: 4px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.1);
    outline: none;
    cursor: pointer;
    accent-color: var(--ac);
  }

  .slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: var(--ac);
    box-shadow: 0 0 8px color-mix(in srgb, var(--ac) 60%, transparent);
    cursor: pointer;
    transition: transform 0.15s;
  }

  .slider::-webkit-slider-thumb:hover { transform: scale(1.15); }
  .slider::-moz-range-thumb {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: var(--ac);
    border: none;
    cursor: pointer;
  }

  /* ── Chip rows ── */
  .chip-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  /* ── Textarea ── */
  .g-textarea {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 9px;
    color: #e9edf7;
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    padding: 10px 14px;
    resize: vertical;
    line-height: 1.55;
    transition: border-color 0.2s;
    width: 100%;
    box-sizing: border-box;
  }
  .g-textarea:focus {
    outline: none;
    border-color: color-mix(in srgb, var(--ac) 50%, transparent);
  }

  /* ── Add ref game button ── */
  .add-ref-btn { align-self: flex-start; margin-top: 4px; }

  /* ── Buttons ── */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 10px 20px;
    border-radius: 9px;
    border: none;
    background: var(--ac);
    color: #0a0e1a;
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s;
    white-space: nowrap;
  }
  .btn-primary:hover { background: var(--ac-lite); }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 10px 18px;
    border-radius: 9px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: transparent;
    color: #cdd5e8;
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s;
    white-space: nowrap;
  }
  .btn-secondary:hover {
    border-color: color-mix(in srgb, var(--ac) 50%, transparent);
    color: #fff;
  }

  .btn-sm {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11.5px;
    font-weight: 500;
    padding: 6px 13px;
    border-radius: 7px;
    border: 1px solid color-mix(in srgb, var(--ac) 35%, transparent);
    background: color-mix(in srgb, var(--ac) 8%, transparent);
    color: var(--ac-soft);
    cursor: pointer;
    transition: background 0.2s;
    white-space: nowrap;
  }
  .btn-sm:hover { background: color-mix(in srgb, var(--ac) 16%, transparent); }

  /* ── Profile strength meter ── */
  .strength-bar-wrap {
    background: #0e1424;
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 12px;
    padding: 18px 20px;
    margin-bottom: 16px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .strength-label-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .strength-pct {
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    font-weight: 700;
    color: var(--ac);
  }

  .strength-track {
    height: 6px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.06);
    overflow: hidden;
  }

  .strength-fill {
    height: 100%;
    width: 0%;
    border-radius: 999px;
    background: var(--ac);
    transition: width 0.35s ease, background 0.35s ease;
  }

  .strength-hint {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11.5px;
    color: #4a5470;
    margin: 0;
  }

  /* ── Sticky CTA ── */
  .sticky-cta {
    position: sticky;
    bottom: 20px;
    z-index: 20;
    pointer-events: none;
  }

  .sticky-cta-inner {
    pointer-events: auto;
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
    background: rgba(10, 14, 26, 0.88);
    backdrop-filter: blur(14px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 14px;
    padding: 14px 20px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5);
  }

  .cta-opts {
    flex: 1 1 auto;
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    align-items: center;
  }

  .filter-group {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  /* ── Results ── */
