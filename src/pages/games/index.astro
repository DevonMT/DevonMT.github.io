  }

  .lookup-input { flex: 1 1 16rem; }

  /* ── Result grids ── */
  .result-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 14px;
    margin-top: 18px;
  }

  @media (min-width: 720px) {
    .result-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1000px) {
    .result-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .grid-status {
    margin-top: 14px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12.5px;
    color: #9aa6c2;
  }
  .grid-status.error { color: #f87171; }

  .releases-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 14px;
    margin-top: 14px;
  }
  @media (min-width: 720px) {
    .releases-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1000px) {
    .releases-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .grid-foot {
    display: flex;
    justify-content: center;
    margin-top: 24px;
  }

  /* ── Keyframes ── */
  @keyframes g-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.45; transform: scale(0.82); }
  }

  @media (prefers-reduced-motion: reduce) {
    .logo-dot, .sync-dot { animation: none; }
  }
</style>

<script>
  // ---- Config ----
  const API_BASE = 'https://games-backend-production-d763.up.railway.app';
  const KEY_NAME = 'devon_key';

  // ---- DOM refs ----
  const gateEl      = document.getElementById('gate')!;
  const dashEl      = document.getElementById('dashboard')!;
  const gateForm    = document.getElementById('gate-form') as HTMLFormElement;
  const gateKey     = document.getElementById('gate-key') as HTMLInputElement;
  const gateSubmit  = document.getElementById('gate-submit') as HTMLButtonElement;
  const gateError   = document.getElementById('gate-error')!;
  const syncStatusEl = document.getElementById('sync-status')!;
  const syncNowBtn  = document.getElementById('sync-now') as HTMLButtonElement;
  const lockBtn     = document.getElementById('lock-btn') as HTMLButtonElement;

  // ---- Taste profile ----
  const tasteToggle     = document.getElementById('taste-toggle') as HTMLButtonElement;
  const tastePanel      = document.getElementById('taste-panel')!;
  const tasteSummaryEl  = document.getElementById('taste-summary')!;
  const tasteFavorites  = document.getElementById('taste-favorites') as HTMLTextAreaElement;
  const tasteNotes      = document.getElementById('taste-notes') as HTMLTextAreaElement;
  const PREFS_KEY = 'games_taste_prefs';

  function getPrefs(): { favoritesNote: string; values: string[]; notes: string } {
    try {
      const raw = localStorage.getItem(PREFS_KEY);
      return raw ? JSON.parse(raw) : { favoritesNote: '', values: [], notes: '' };
    } catch { return { favoritesNote: '', values: [], notes: '' }; }
  }

  function savePrefs() {
    const values = [...document.querySelectorAll<HTMLInputElement>('.taste-chip input:checked')].map((el) => el.value);
    const prefs = { favoritesNote: tasteFavorites.value.trim(), values, notes: tasteNotes.value.trim() };
    localStorage.setItem(PREFS_KEY, JSON.stringify(prefs));
    renderTasteSummary(prefs);
    // Sync to server (fire-and-forget — failure is non-fatal, localStorage still works)
    api('/preferences', { method: 'POST', body: JSON.stringify(prefs) }).catch(() => {});
  }

  function renderTasteSummary(prefs: { favoritesNote: string; values: string[]; notes: string }) {
    const parts: string[] = [];
    if (prefs.favoritesNote) {
      const first3 = prefs.favoritesNote.split(',').slice(0, 3).map((s) => s.trim()).filter(Boolean).join(', ');
      if (first3) parts.push(first3);
    }
    if (prefs.values.length) parts.push(`${prefs.values.length} value${prefs.values.length === 1 ? '' : 's'} set`);
    tasteSummaryEl.textContent = parts.length
      ? parts.join(' · ')
      : 'Not configured — tell Claude what you like';
  }

  function applyPrefsToForm(prefs: { favoritesNote: string; values: string[]; notes: string }) {
    tasteFavorites.value = prefs.favoritesNote || '';
    tasteNotes.value = prefs.notes || '';
    document.querySelectorAll<HTMLInputElement>('.taste-chip input').forEach((el) => {
      el.checked = prefs.values.includes(el.value);
    });
    renderTasteSummary(prefs);
  }

  async function loadPrefsIntoForm() {
    // Try server first (cross-device sync), fall back to localStorage.
    try {
      const data = await api('/preferences');
      if (data?.prefs && typeof data.prefs === 'object') {
        const serverPrefs = {
          favoritesNote: String(data.prefs.favoritesNote ?? ''),
          values: Array.isArray(data.prefs.values) ? data.prefs.values : [],
          notes: String(data.prefs.notes ?? ''),
        };
        localStorage.setItem(PREFS_KEY, JSON.stringify(serverPrefs));
        applyPrefsToForm(serverPrefs);
        return;
      }
    } catch { /* no key yet or backend down — fall through */ }
    applyPrefsToForm(getPrefs());
  }

  tasteToggle.addEventListener('click', () => {
    const open = !tastePanel.hidden;
    tastePanel.hidden = open;
    tasteToggle.setAttribute('aria-expanded', String(!open));
  });
  tasteFavorites.addEventListener('input', savePrefs);
  tasteNotes.addEventListener('input', savePrefs);
  document.querySelectorAll<HTMLInputElement>('.taste-chip input').forEach((el) => el.addEventListener('change', savePrefs));

  // ---- Helpers ----
  function getKey(): string | null { return localStorage.getItem(KEY_NAME); }

  function fmtDate(d: Date): string { return d.toISOString().slice(0, 10); }

  function relativeTime(iso: string | null | undefined): string {
    if (!iso) return 'never';
    const then = new Date(iso).getTime();
    if (Number.isNaN(then)) return 'unknown';
    const secs = Math.round((Date.now() - then) / 1000);
    const units: [number, string][] = [
      [60, 'second'], [60, 'minute'], [24, 'hour'], [Infinity, 'day'],
    ];
    let v = secs; let unit = 'second';
    for (let i = 0; i < units.length; i++) {
      unit = units[i][1];
      if (v < units[i][0]) break;
      v = Math.floor(v / units[i][0]);
    }
    const n = Math.max(v, 0);
    return `${n} ${unit}${n === 1 ? '' : 's'} ago`;
  }

  function escapeHtml(s: string): string {
    const div = document.createElement('div');
    div.textContent = s ?? '';
    return div.innerHTML;
  }

  async function api(path: string, init: RequestInit = {}): Promise<any> {
    const key = getKey();
    if (!key) throw new Error('No access key');
    const res = await fetch(`${API_BASE}${path}`, {
      ...init,
      headers: {
        'x-api-secret': key,
        'Content-Type': 'application/json',
        ...(init.headers || {}),
      },
    });
    if (res.status === 401) {
      localStorage.removeItem(KEY_NAME);
      showGate('Access key rejected. Please try again.');
      throw new Error('Unauthorized');
    }
    if (!res.ok) {
      const body = await res.json().catch(() => null);
      throw new Error(body?.error || body?.warning || `Request failed (${res.status})`);
    }
    return res.json();
  }

  // ---- Gate ----
  function showGate(message?: string) {
    dashEl.hidden = true;
    gateEl.hidden = false;
    if (message) { gateError.textContent = message; gateError.hidden = false; }
    else { gateError.hidden = true; }
    gateKey.value = '';
    gateKey.focus();
  }

  function showDashboard() { gateEl.hidden = true; dashEl.hidden = false; }

  gateForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const key = gateKey.value.trim();
    if (!key) return;
    gateError.hidden = true;
    gateSubmit.disabled = true;
    gateSubmit.innerHTML = '<span class="spinner"></span> Checking…';
    try {
      const res = await fetch(`${API_BASE}/health`, { headers: { 'x-api-secret': key } });
      if (res.status === 401) {
        gateError.textContent = 'Access key rejected. Please try again.';
        gateError.hidden = false;
        return;
      }
      if (!res.ok) {
        gateError.textContent = `Backend error (${res.status}). Try again later.`;
        gateError.hidden = false;
        return;
      }
      localStorage.setItem(KEY_NAME, key);
      showDashboard();
      initDashboard();
    } catch {
      gateError.textContent = 'Could not reach the backend. Is it running?';
      gateError.hidden = false;
    } finally {
      gateSubmit.disabled = false;
      gateSubmit.textContent = 'Unlock';
    }
  });

  lockBtn.addEventListener('click', () => { localStorage.removeItem(KEY_NAME); showGate(); });

  // ---- Sync status ----
  async function loadSyncStatus() {
    try {
      const data = await api('/steam/sync-status');
      syncStatusEl.textContent = `Steam library last synced ${relativeTime(data.lastSteamSync)}`;
      syncStatusEl.classList.toggle('stale', !!data.stale);
    } catch {
      syncStatusEl.textContent = 'Sync status unavailable';
    }
  }

  syncNowBtn.addEventListener('click', async () => {
    syncNowBtn.disabled = true;
    const original = syncNowBtn.textContent;
    syncNowBtn.innerHTML = '<span class="spinner"></span> Syncing…';
    try {
      await api('/steam/library/refresh', { method: 'POST' });
      await loadSyncStatus();
    } catch {
      syncStatusEl.textContent = 'Sync failed — try again';
      syncStatusEl.classList.add('stale');
    } finally {
      syncNowBtn.disabled = false;
      syncNowBtn.textContent = original;
    }
  });

  // ---- Tabs ----
  function switchTab(name: string) {
    document.querySelectorAll<HTMLElement>('.tab-btn').forEach((btn) => {
      btn.classList.toggle('active', btn.dataset.tab === name);
    });
    document.querySelectorAll<HTMLElement>('.tab-content').forEach((panel) => {
      panel.hidden = panel.dataset.tab !== name;
    });
    sessionStorage.setItem('games_active_tab', name);
  }

  document.querySelectorAll<HTMLButtonElement>('.tab-btn').forEach((btn) => {
    btn.addEventListener('click', () => switchTab(btn.dataset.tab!));
  });

  // ---- Filter options ----
  const PLATFORM_OPTIONS = [
    { value: 'All',             label: 'All' },
    { value: 'pc',              label: 'PC' },
    { value: 'playstation5',    label: 'PS5' },
    { value: 'playstation4',    label: 'PS4' },
    { value: 'xbox-series-x',   label: 'Xbox' },
    { value: 'nintendo-switch', label: 'Switch' },
  ];
  const GENRE_OPTIONS = [
    { value: 'All',        label: 'All' },
    { value: 'action',     label: 'Action' },
    { value: 'rpg',        label: 'RPG' },
    { value: 'strategy',   label: 'Strategy' },
    { value: 'sports',     label: 'Sports' },
    { value: 'simulation', label: 'Simulation' },
  ];
  const TYPE_OPTIONS = [
    { value: 'All',           label: 'All' },
    { value: 'AAA',           label: 'AAA' },
    { value: 'indie',         label: 'Indie' },
    { value: 'early_access',  label: 'Early Access' },
    { value: 'multiplayer',   label: 'Multiplayer' },
    { value: 'single_player', label: 'Single Player' },
  ];

  // ---- State ----
  const discoverState = { platform: 'All', genre: 'All' };
  const browseState   = { type: 'All', page: 1 };

  function buildChips(
    container: HTMLElement,
    options: { value: string; label: string }[],
    stateObj: Record<string, any>,
    key: string,
    onChange?: () => void,
  ) {
    container.innerHTML = '';
    options.forEach(({ value, label }) => {
      const chip = document.createElement('button');
      chip.type = 'button';
      chip.className = 'chip' + (stateObj[key] === value ? ' active' : '');
      chip.textContent = label;
      chip.addEventListener('click', () => {
        stateObj[key] = value;
        container.querySelectorAll('.chip').forEach((c) => c.classList.remove('active'));
        chip.classList.add('active');
        onChange?.();
      });
      container.appendChild(chip);
    });
  }

  // ---- Confidence helpers ----
  function confClass(score: number): { text: string; bg: string } {
    if (score >= 75) return { text: 'conf-high', bg: 'conf-high-bg' };
    if (score >= 50) return { text: 'conf-mid',  bg: 'conf-mid-bg' };
    return { text: 'conf-low', bg: 'conf-low-bg' };
  }

  // ---- Own tab: backlog ----
  const backlogBtn       = document.getElementById('backlog-btn') as HTMLButtonElement;
  const backlogStatus    = document.getElementById('backlog-status')!;
  const backlogGrid      = document.getElementById('backlog-grid')!;
  const backlogThreshold = document.getElementById('backlog-threshold') as HTMLSelectElement;
  const EXCLUDED_KEY = 'games_backlog_excluded';

  function getExcluded(): Set<number> {
    try {
      const raw = localStorage.getItem(EXCLUDED_KEY);
      return new Set(raw ? JSON.parse(raw) : []);
    } catch { return new Set(); }
  }

  function saveExcluded(ex: Set<number>) {
    localStorage.setItem(EXCLUDED_KEY, JSON.stringify([...ex]));
  }

  function updateExclusionNote() {
    const ex = getExcluded();
    let note = document.getElementById('backlog-exclusion-note');
    if (ex.size === 0) { note?.remove(); return; }
    if (!note) {
      note = document.createElement('p');
      note.id = 'backlog-exclusion-note';
      note.className = 'grid-status backlog-exclusion-note';
      backlogGrid.parentElement!.insertBefore(note, backlogGrid);
    }
    note.innerHTML = `${ex.size} game${ex.size === 1 ? '' : 's'} excluded · <button class="inline-link" id="backlog-reset">Reset</button>`;
    document.getElementById('backlog-reset')?.addEventListener('click', () => {
      localStorage.removeItem(EXCLUDED_KEY);
      note!.remove();
    });
  }

  function renderBacklogCard(pick: any): HTMLElement {
    const card = document.createElement('article');
    card.className = 'backlog-card';
    const score = Math.max(0, Math.min(100, Math.round(pick.confidenceScore ?? 0)));
    const cls = confClass(score);
    const hours = pick.hoursPlayed ?? 0;
    card.innerHTML = `
      <div class="backlog-title-row">
        <a class="backlog-name" href="https://store.steampowered.com/app/${pick.appId}/" target="_blank" rel="noopener">${escapeHtml(pick.name || 'Unknown')} ↗</a>
        <span class="backlog-hours">${hours}h played</span>
        <button class="backlog-exclude" type="button" title="Exclude from future picks">✕ Exclude</button>
      </div>
      <div class="reco-head">
        <span class="reco-label">Confidence</span>
        <span class="reco-score ${cls.text}">${score}</span>
      </div>
      <div class="reco-bar"><span class="${cls.bg}" style="width:${score}%"></span></div>
      <p class="reco-text">${escapeHtml(pick.reasoning || '')}</p>
    `;
    card.querySelector('.backlog-exclude')!.addEventListener('click', () => {
      const ex = getExcluded();
      ex.add(pick.appId);
      saveExcluded(ex);
      card.remove();
      updateExclusionNote();
    });
    return card;
  }

  async function loadBacklogPicks() {
    const threshold = backlogThreshold.value;
    const excluded = [...getExcluded()];
    const excludeParam = excluded.length ? `&exclude=${excluded.join(',')}` : '';
    backlogStatus.hidden = false;
    backlogStatus.classList.remove('error');
    backlogStatus.innerHTML = '<span class="spinner"></span> Finding picks from your backlog…';
    backlogGrid.innerHTML = '';
    backlogBtn.disabled = true;
    try {
      const data = await api(`/steam/backlog-picks?threshold=${threshold}&limit=5${excludeParam}`, {
        method: 'POST',
        body: JSON.stringify({ preferences: getPrefs() }),
      });
      const picks: any[] = data.picks ?? [];
      if (picks.length === 0) {
        backlogStatus.textContent = data.warning ?? 'No picks found.';
        return;
      }
      const count = data.candidateCount ?? picks.length;
      backlogStatus.textContent = `Top picks from ${count} games with < ${threshold}h played`;
      backlogStatus.hidden = false;
      picks.forEach((p) => backlogGrid.appendChild(renderBacklogCard(p)));
      updateExclusionNote();
    } catch (err: any) {
      if (err?.message !== 'Unauthorized') {
        backlogStatus.classList.add('error');
        backlogStatus.hidden = false;
        backlogStatus.textContent = `Couldn't load picks: ${err?.message || 'unknown error'}`;
      }
    } finally {
      backlogBtn.disabled = false;
    }
  }

  backlogBtn.addEventListener('click', loadBacklogPicks);

  // ---- Discover tab ----
  const discoverBtn    = document.getElementById('discover-btn') as HTMLButtonElement;
  const discoverStatus = document.getElementById('discover-status')!;
  const discoverGrid   = document.getElementById('discover-grid')!;
  const browseToggle   = document.getElementById('browse-toggle') as HTMLButtonElement;
  const browseSection  = document.getElementById('browse-section')!;

  function renderResultCard(item: { name: string; platforms: string[]; description: string; confidenceScore: number; reasoning: string }): HTMLElement {
    const card = document.createElement('article');
    card.className = 'discover-card';
    const score = Math.max(0, Math.min(100, Math.round(item.confidenceScore ?? 0)));
    const cls = confClass(score);
    const platformsText = (item.platforms ?? []).join(' · ');
    card.innerHTML = `
      <div>
        <span class="discover-name">${escapeHtml(item.name || 'Unknown')}</span>
        ${platformsText ? `<span class="discover-platforms">${escapeHtml(platformsText)}</span>` : ''}
      </div>
      ${item.description ? `<p class="reco-text">${escapeHtml(item.description)}</p>` : ''}
      <div class="reco-head">
        <span class="reco-label">Match</span>
        <span class="reco-score ${cls.text}">${score}</span>
      </div>
      <div class="reco-bar"><span class="${cls.bg}" style="width:${score}%"></span></div>
      <p class="reco-text">${escapeHtml(item.reasoning || '')}</p>
    `;
    return card;
  }

  async function loadDiscover() {
    discoverStatus.classList.remove('error');
    discoverStatus.hidden = false;
    discoverStatus.innerHTML = '<span class="spinner"></span> Finding recommendations…';
    discoverGrid.innerHTML = '';
    discoverBtn.disabled = true;
    try {
      const data = await api('/recommendations/discover', {
        method: 'POST',
        body: JSON.stringify({
          platforms: discoverState.platform === 'All' ? [] : [discoverState.platform],
          genres:    discoverState.genre    === 'All' ? [] : [discoverState.genre],
          limit: 8,
          preferences: getPrefs(),
        }),
      });
      const picks: any[] = data.picks ?? [];
      if (picks.length === 0) {
        discoverStatus.textContent = 'No recommendations found. Try adjusting your taste profile.';
        return;
      }
      discoverStatus.hidden = true;
      picks.forEach((p) => discoverGrid.appendChild(renderResultCard(p)));
    } catch (err: any) {
      if (err?.message !== 'Unauthorized') {
        discoverStatus.classList.add('error');
        discoverStatus.hidden = false;
        discoverStatus.textContent = `Couldn't get recommendations: ${err?.message || 'unknown error'}`;
      }
    } finally {
      discoverBtn.disabled = false;
    }
  }

  discoverBtn.addEventListener('click', loadDiscover);

  browseToggle.addEventListener('click', () => {
    const opening = browseSection.hidden;
    browseSection.hidden = !opening;
    browseToggle.textContent = opening ? 'Browse upcoming releases ▲' : 'Browse upcoming releases ▾';
    if (opening && releasesGrid.childElementCount === 0) {
      browseState.page = 1;
      loadReleases(false);
    }
  });

  // ---- Browse / releases ----
  const sinceInput  = document.getElementById('since') as HTMLInputElement;
  const untilInput  = document.getElementById('until') as HTMLInputElement;
  const applyBtn    = document.getElementById('apply-filters') as HTMLButtonElement;
  const gridStatus  = document.getElementById('grid-status')!;
  const releasesGrid = document.getElementById('releases-grid')!;
  const loadMoreBtn = document.getElementById('load-more') as HTMLButtonElement;

  function setDefaultDates() {
    const now = new Date();
    const since = new Date(now); since.setDate(since.getDate() - 90);
    const until = new Date(now); until.setDate(until.getDate() + 90);
    sinceInput.value = fmtDate(since);
    untilInput.value = fmtDate(until);
  }

  function buildReleaseQuery(): string {
    const params = new URLSearchParams();
    const cats = [browseState.type, discoverState.genre].filter((v) => v !== 'All').join(',');
    if (cats) params.set('categories', cats);
    if (discoverState.platform !== 'All') params.set('platforms', discoverState.platform);
    if (sinceInput.value)  params.set('since', sinceInput.value);
    if (untilInput.value)  params.set('until', untilInput.value);
    params.set('page', String(browseState.page));
    return params.toString();
  }

  async function loadReleases(append: boolean) {
    gridStatus.classList.remove('error');
    gridStatus.hidden = false;
    gridStatus.innerHTML = '<span class="spinner"></span> Loading releases…';
    if (!append) { releasesGrid.innerHTML = ''; loadMoreBtn.hidden = true; }
    applyBtn.disabled = true;
    try {
      const data = await api(`/releases?${buildReleaseQuery()}`);
      const games = data.releases || [];
      if (!append && games.length === 0) {
        gridStatus.textContent = 'No releases match these filters.';
      } else {
        gridStatus.hidden = true;
      }
      games.forEach((g: any) => releasesGrid.appendChild(renderCard(g)));
      loadMoreBtn.hidden = !data.hasNext;
    } catch (err: any) {
      if (err?.message !== 'Unauthorized') {
        gridStatus.classList.add('error');
        gridStatus.hidden = false;
        gridStatus.textContent = `Could not load releases: ${err?.message || 'unknown error'}`;
      }
    } finally {
      applyBtn.disabled = false;
    }
  }

  applyBtn.addEventListener('click', () => { browseState.page = 1; loadReleases(false); });
  loadMoreBtn.addEventListener('click', () => { browseState.page += 1; loadReleases(true); });

  function metacriticClass(score: number): string {
    if (score >= 75) return 'high';
    if (score >= 50) return 'mid';
    return 'low';
  }

  function renderCard(game: any): HTMLElement {
    const card = document.createElement('article');
    card.className = 'game-card';
    const platforms: string[] = Array.isArray(game.platforms) ? game.platforms : [];
    const platformText = platforms.slice(0, 6).map(escapeHtml).join(' · ');
    const mc = typeof game.metacriticScore === 'number' && game.metacriticScore > 0
      ? `<span class="metacritic ${metacriticClass(game.metacriticScore)}">${game.metacriticScore}</span>`
      : '';
    const releaseDate = game.releaseDate ? escapeHtml(game.releaseDate) : 'TBA';
    const byline = [game.developer, game.publisher]
      .filter(Boolean).filter((v, i, a) => a.indexOf(v) === i).join(' · ');
    const allCategories: string[] = Array.isArray(game.categories) && game.categories.length
      ? game.categories : game.category ? [game.category] : [];
    const categoriesText = allCategories.map(escapeHtml).join(' · ');
    card.innerHTML = `
      <h3>${escapeHtml(game.name || 'Untitled')}</h3>
      <div class="game-meta">
        <span>${releaseDate}</span>
        ${mc}
      </div>
      ${categoriesText ? `<p class="game-categories">${categoriesText}</p>` : ''}
      ${byline ? `<p class="game-byline">${escapeHtml(byline)}</p>` : ''}
      ${platformText ? `<p class="game-platforms">${platformText}</p>` : ''}
      ${game.description ? `<p class="game-desc">${escapeHtml(game.description)}</p>` : ''}
      <div class="card-actions">
        <button class="rate-btn" type="button">Rate this</button>
        ${game.steamAppId
          ? `<a class="steam-link" href="https://store.steampowered.com/app/${game.steamAppId}/" target="_blank" rel="noopener">Steam ↗</a>`
          : ''}
      </div>
      <div class="reco" hidden></div>
    `;
    const rateBtn = card.querySelector('.rate-btn') as HTMLButtonElement;
    const recoEl  = card.querySelector('.reco') as HTMLElement;
    rateBtn.addEventListener('click', () => rate(game, rateBtn, recoEl));
    return card;
  }

  async function rate(game: any, btn: HTMLButtonElement, recoEl: HTMLElement) {
    const id = game.rawgId ?? game.id;
    if (id == null) return;
    btn.disabled = true;
    const original = btn.textContent;
    btn.innerHTML = '<span class="spinner"></span> Rating…';
    recoEl.hidden = false;
    recoEl.innerHTML = '<p class="reco-text"><span class="spinner"></span> Asking for a recommendation…</p>';
    try {
      const data = await api('/recommendations', {
        method: 'POST',
        body: JSON.stringify({ gameIds: [id], preferences: getPrefs() }),
      });
      const reco = (data.recommendations || [])[0];
      if (!reco) { recoEl.innerHTML = '<p class="reco-error">No recommendation returned.</p>'; return; }
      const score = Math.max(0, Math.min(100, Math.round(reco.confidenceScore)));
      const cls = confClass(score);
      recoEl.innerHTML = `
        <div class="reco-head">
          <span class="reco-label">Confidence</span>
          <span class="reco-score ${cls.text}">${score}</span>
        </div>
        <div class="reco-bar"><span class="${cls.bg}" style="width:${score}%"></span></div>
        <p class="reco-text">${escapeHtml(reco.reasoning || '')}</p>
      `;
    } catch (err: any) {
      if (err?.message !== 'Unauthorized') {
        recoEl.innerHTML = `<p class="reco-error">Couldn't rate this: ${escapeHtml(err?.message || 'unknown error')}</p>`;
      }
    } finally {
      btn.disabled = false;
      btn.textContent = original;
    }
  }

  // ---- Lookup tab ----
  const lookupInput  = document.getElementById('lookup-input') as HTMLInputElement;
  const lookupBtn    = document.getElementById('lookup-btn') as HTMLButtonElement;
  const lookupStatus = document.getElementById('lookup-status')!;
  const lookupGrid   = document.getElementById('lookup-grid')!;

  async function runLookup() {
    const query = lookupInput.value.trim();
    if (!query) { lookupInput.focus(); return; }
    lookupStatus.classList.remove('error');
    lookupStatus.hidden = false;
    lookupStatus.innerHTML = '<span class="spinner"></span> Looking that up…';
    lookupGrid.innerHTML = '';
    lookupBtn.disabled = true;
    try {
      const data = await api('/recommendations/lookup', {
        method: 'POST',
        body: JSON.stringify({ query, preferences: getPrefs() }),
      });
      const results: any[] = data.results ?? [];
      if (results.length === 0) {
        lookupStatus.textContent = 'No results found.';
        return;
      }
      lookupStatus.hidden = true;
      results.forEach((r) => lookupGrid.appendChild(renderResultCard(r)));
    } catch (err: any) {
      if (err?.message !== 'Unauthorized') {
        lookupStatus.classList.add('error');
        lookupStatus.hidden = false;
        lookupStatus.textContent = `Couldn't look that up: ${err?.message || 'unknown error'}`;
      }
    } finally {
      lookupBtn.disabled = false;
    }
  }

  lookupBtn.addEventListener('click', runLookup);
  lookupInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') runLookup(); });

  // ---- Init ----
  async function initDashboard() {
    await loadPrefsIntoForm();
    buildChips(
      document.getElementById('discover-platform-chips')!,
      PLATFORM_OPTIONS,
      discoverState,
      'platform',
    );
    buildChips(
      document.getElementById('discover-genre-chips')!,
      GENRE_OPTIONS,
      discoverState,
      'genre',
    );
    buildChips(
      document.getElementById('type-chips')!,
      TYPE_OPTIONS,
      browseState,
      'type',
    );
    setDefaultDates();
    loadSyncStatus();
    updateExclusionNote();
    const savedTab = sessionStorage.getItem('games_active_tab') ?? 'own';
    switchTab(savedTab);
  }

  // ---- Boot ----
  if (getKey()) {
    showDashboard();
    initDashboard().catch(() => {});
    // Honor hash deep-links from the hub: /games#own, #discover, #lookup
    const hash = location.hash.replace('#', '');
    if (['own', 'discover', 'lookup'].includes(hash)) switchTab(hash);
  } else {
    showGate();
  }
</script>
