---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout
  title="Games — Devon Troedel"
  description="Private games dashboard."
>
  <Header />
  <main>
    <!-- Access gate: shown until a key is stored in sessionStorage -->
    <section id="gate" class="gate" hidden>
      <div class="gate-card">
        <p class="eyebrow mono">// private</p>
        <h1>Games dashboard</h1>
        <p class="gate-intro">
          This page is password-gated. Enter the access key to continue.
        </p>
        <form id="gate-form" class="gate-form" autocomplete="off">
          <input
            id="gate-key"
            type="password"
            class="gate-input"
            placeholder="Access key"
            aria-label="Access key"
            required
          />
          <button type="submit" class="btn btn-primary" id="gate-submit">Unlock</button>
        </form>
        <p id="gate-error" class="gate-error" role="alert" hidden></p>
      </div>
    </section>

    <!-- Dashboard: populated by JS once authenticated -->
    <section id="dashboard" class="dashboard" hidden>
      <div class="page-head">
        <p class="eyebrow mono">// games</p>
        <h1>Game releases</h1>
      </div>

      <!-- Sync status bar -->
      <div class="sync-bar">
        <span id="sync-status" class="sync-status mono">Loading sync status…</span>
        <button id="sync-now" class="btn sync-btn" type="button">Sync now</button>
        <button id="lock-btn" class="btn lock-btn" type="button" title="Forget access key">Lock</button>
      </div>

      <!-- Taste profile quiz -->
      <div class="taste-section">
        <button id="taste-toggle" class="taste-toggle" type="button" aria-expanded="false">
          <span class="eyebrow mono" style="margin:0">// taste profile</span>
          <span id="taste-summary" class="taste-summary">Not configured — tell Claude what you like ▾</span>
        </button>
        <div id="taste-panel" class="taste-panel" hidden>
          <div class="taste-field">
            <label class="filter-label mono" for="taste-favorites">Favorite games not on Steam (or where your hours don't reflect how much you love them)</label>
            <textarea id="taste-favorites" class="taste-textarea" rows="2" placeholder="e.g. Tales of Arise, FFXIV, Kingdom Hearts, FFX, Chained Echoes, Dark Souls, WoW…"></textarea>
          </div>
          <div class="taste-field">
            <span class="filter-label mono">What matters most to you in a game</span>
            <div class="taste-values">
              <label class="taste-chip"><input type="checkbox" value="story" hidden> Story &amp; Narrative</label>
              <label class="taste-chip"><input type="checkbox" value="build-depth" hidden> Build Depth &amp; Systems</label>
              <label class="taste-chip"><input type="checkbox" value="combat" hidden> Combat Feel</label>
              <label class="taste-chip"><input type="checkbox" value="exploration" hidden> World Exploration</label>
              <label class="taste-chip"><input type="checkbox" value="lore" hidden> Lore &amp; World-building</label>
              <label class="taste-chip"><input type="checkbox" value="social" hidden> MMO / Social</label>
              <label class="taste-chip"><input type="checkbox" value="emotional" hidden> Emotional Impact</label>
              <label class="taste-chip"><input type="checkbox" value="mechanics" hidden> Unique Mechanics</label>
              <label class="taste-chip"><input type="checkbox" value="fantasy" hidden> Fantasy Setting</label>
            </div>
          </div>
          <div class="taste-field">
            <label class="filter-label mono" for="taste-notes">Anything else Claude should know</label>
            <textarea id="taste-notes" class="taste-textarea" rows="2" placeholder="e.g. FFXII for the Gambit system and job builds, not the story. I value deep MMO worlds but not necessarily the grind."></textarea>
          </div>
        </div>
      </div>

      <!-- Filter bar -->
      <div class="filters">
        <div class="filter-group" data-group="type">
          <span class="filter-label mono">Type</span>
          <div class="chips" id="type-chips"></div>
        </div>
        <div class="filter-group" data-group="genre">
          <span class="filter-label mono">Genre</span>
          <div class="chips" id="genre-chips"></div>
        </div>
        <div class="filter-group" data-group="platform">
          <span class="filter-label mono">Platform</span>
          <div class="chips" id="platform-chips"></div>
        </div>
        <div class="filter-group dates">
          <label class="date-field">
            <span class="filter-label mono">Since</span>
            <input type="date" id="since" class="date-input" />
          </label>
          <label class="date-field">
            <span class="filter-label mono">Until</span>
            <input type="date" id="until" class="date-input" />
          </label>
          <button id="apply-filters" class="btn btn-primary apply-btn" type="button">Apply</button>
        </div>
      </div>

      <!-- Results -->
      <p id="grid-status" class="grid-status mono" hidden></p>
      <div id="releases-grid" class="releases-grid"></div>
      <div class="grid-foot">
        <button id="load-more" class="btn" type="button" hidden>Load more</button>
      </div>

      <!-- Backlog picks -->
      <div class="backlog-section">
        <div class="backlog-head">
          <p class="eyebrow mono">// backlog</p>
          <h2>What should I play?</h2>
          <p class="backlog-intro">Picks from games you already own but haven't touched.</p>
        </div>
        <div class="backlog-controls">
          <span class="filter-label mono">Games with less than</span>
          <select id="backlog-threshold" class="threshold-select">
            <option value="2">2h played</option>
            <option value="5" selected>5h played</option>
            <option value="10">10h played</option>
            <option value="20">20h played</option>
          </select>
          <button id="backlog-btn" class="btn btn-primary" type="button">Find picks</button>
        </div>
        <p id="backlog-status" class="grid-status mono" hidden></p>
        <div id="backlog-grid" class="backlog-grid"></div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style is:global>
  /* Chips are created dynamically in JS so must use global scope */
  .chip {
    font-family: var(--font-mono, monospace);
    font-size: 0.8rem;
    color: var(--color-text-muted, #94a3b8);
    background: transparent;
    border: 1px solid var(--color-border, #334155);
    border-radius: 999px;
    padding: 0.3rem 0.85rem;
    cursor: pointer;
    transition: color 0.15s, background 0.15s, border-color 0.15s;
  }
  .chip:hover {
    color: #fff;
    border-color: #0d9488;
  }
  .chip.active {
    color: #fff;
    background: #0d9488;
    border-color: #0d9488;
    font-weight: 600;
  }
  .backlog-exclude {
    margin-left: auto;
    font-family: var(--font-mono, monospace);
    font-size: 0.72rem;
    color: #64748b;
    background: transparent;
    border: 1px solid #334155;
    border-radius: 999px;
    padding: 0.2rem 0.6rem;
    cursor: pointer;
    transition: color 0.15s, border-color 0.15s;
    white-space: nowrap;
  }
  .backlog-exclude:hover {
    color: #f87171;
    border-color: #f87171;
  }
  .inline-link {
    background: none;
    border: none;
    padding: 0;
    color: #0d9488;
    font-family: var(--font-mono, monospace);
    font-size: inherit;
    cursor: pointer;
    text-decoration: underline;
  }
  .inline-link:hover { color: #fff; }
  .backlog-exclusion-note {
    margin-bottom: 0;
  }
</style>

<style>
  /* ---- Access gate ---- */
  .gate {
    min-height: 60vh;
    display: grid;
    place-items: center;
    padding-block: var(--space-2xl);
  }
  .gate-card {
    width: 100%;
    max-width: 28rem;
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: var(--space-lg);
    box-shadow: var(--shadow);
  }
  .gate-intro {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    margin-top: var(--space-sm);
  }
  .gate-form {
    display: flex;
    gap: var(--space-sm);
    margin-top: var(--space-md);
    flex-wrap: wrap;
  }
  .gate-input,
  .date-input {
    flex: 1 1 12rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    color: var(--color-text);
    font-family: var(--font-mono);
    font-size: 0.95rem;
    padding: 0.7rem 0.9rem;
  }
  .gate-input:focus,
  .date-input:focus {
    outline: 2px solid var(--color-accent);
    outline-offset: 1px;
  }
  .gate-error {
    color: #f87171;
    font-size: 0.9rem;
    margin-top: var(--space-sm);
  }

  /* ---- Page head ---- */
  .page-head {
    padding-block: var(--space-xl) var(--space-md);
  }
  .eyebrow {
    color: var(--color-accent);
    font-size: 0.9rem;
    letter-spacing: 0.04em;
    margin-bottom: var(--space-xs);
  }

  /* ---- Sync bar ---- */
  .sync-bar {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    flex-wrap: wrap;
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: var(--space-sm) var(--space-md);
  }
  .sync-status {
    flex: 1 1 auto;
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }
  .sync-status.stale {
    color: #f59e0b;
  }
  .sync-btn,
  .lock-btn {
    font-size: 0.8rem;
    padding: 0.45rem 0.9rem;
  }
  .lock-btn {
    border-color: var(--color-border);
    color: var(--color-text-muted);
  }

  /* ---- Taste profile ---- */
  .taste-section {
    margin-top: var(--space-md);
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .taste-toggle {
    width: 100%;
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-sm) var(--space-md);
    background: transparent;
    border: none;
    cursor: pointer;
    text-align: left;
  }
  .taste-toggle:hover { background: var(--color-surface); }
  .taste-summary {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }
  .taste-panel {
    padding: var(--space-md);
    border-top: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }
  .taste-field {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }
  .taste-textarea {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    color: var(--color-text);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    padding: 0.6rem 0.8rem;
    resize: vertical;
    line-height: 1.5;
  }
  .taste-textarea:focus {
    outline: 2px solid var(--color-accent);
    outline-offset: 1px;
  }
  .taste-values {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }
  .taste-chip {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 0.3rem 0.85rem;
    cursor: pointer;
    transition: color 0.15s, background 0.15s, border-color 0.15s;
    user-select: none;
  }
  .taste-chip:has(input:checked) {
    color: #fff;
    background: #0d9488;
    border-color: #0d9488;
    font-weight: 600;
  }

  /* ---- Filters ---- */
  .filters {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    margin-top: var(--space-md);
    padding: var(--space-md);
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
  }
  .filter-group {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }
  .filter-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-faint);
  }
  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }
  /* chip styles live in the is:global block above */
  .dates {
    gap: var(--space-md);
  }
  .date-field {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .date-input {
    flex: 0 1 auto;
  }
  .apply-btn {
    align-self: flex-end;
    font-size: 0.85rem;
    padding: 0.55rem 1.1rem;
  }

  /* ---- Grid ---- */
  .grid-status {
    margin-top: var(--space-md);
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }
  .grid-status.error {
    color: #f87171;
  }
  .releases-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
    margin-top: var(--space-md);
  }
  .game-card {
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    transition: border-color var(--transition), transform var(--transition);
  }
  .game-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
  }
  .game-card h3 {
    font-size: 1.1rem;
  }
  .game-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-xs) var(--space-sm);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }
  .metacritic {
    font-weight: 700;
    color: var(--color-bg);
    background: var(--color-text-muted);
    border-radius: var(--radius-sm);
    padding: 0.1rem 0.5rem;
  }
  .metacritic.high { background: #22c55e; }
  .metacritic.mid { background: #f59e0b; }
  .metacritic.low { background: #ef4444; }
  .game-platforms {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-faint);
  }
  .game-categories {
    font-size: 0.75rem;
    color: #0d9488;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .game-byline {
    font-size: 0.8rem;
    color: var(--color-text-faint);
    font-family: var(--font-mono);
  }
  .game-desc {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card-actions {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-top: auto;
    flex-wrap: wrap;
  }
  .rate-btn {
    font-size: 0.8rem;
    padding: 0.45rem 0.9rem;
  }
  .steam-link {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    text-decoration: none;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 0.45rem 0.8rem;
    transition: color var(--transition), border-color var(--transition);
  }
  .steam-link:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  /* ---- Recommendation result ---- */
  .reco {
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-sm);
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }
  .reco-head {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }
  .reco-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-faint);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .reco-score {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 700;
  }
  .reco-bar {
    height: 6px;
    border-radius: 999px;
    background: var(--color-surface);
    overflow: hidden;
  }
  .reco-bar > span {
    display: block;
    height: 100%;
    border-radius: 999px;
    transition: width var(--transition);
  }
  .conf-high  { color: var(--color-accent); }
  .conf-high-bg  { background: var(--color-accent); }
  .conf-mid   { color: #f59e0b; }
  .conf-mid-bg   { background: #f59e0b; }
  .conf-low   { color: var(--color-text-muted); }
  .conf-low-bg   { background: var(--color-text-muted); }
  .reco-text {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    line-height: 1.55;
  }
  .reco-error {
    font-size: 0.85rem;
    color: #f87171;
  }

  .grid-foot {
    display: flex;
    justify-content: center;
    margin-top: var(--space-lg);
  }

  /* spinner for loading states */
  .spinner {
    display: inline-block;
    width: 0.85em;
    height: 0.85em;
    border: 2px solid currentColor;
    border-right-color: transparent;
    border-radius: 50%;
    animation: spin 0.6s linear infinite;
    vertical-align: -0.1em;
  }
  @keyframes spin { to { transform: rotate(360deg); } }
  button[disabled] { opacity: 0.6; cursor: progress; }

  @media (min-width: 720px) {
    .releases-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* ---- Backlog section ---- */
  .backlog-section {
    margin-top: var(--space-2xl);
    padding-top: var(--space-xl);
    border-top: 1px solid var(--color-border);
  }
  .backlog-intro {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    margin-top: var(--space-xs);
  }
  .backlog-controls {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    flex-wrap: wrap;
    margin-top: var(--space-md);
  }
  .threshold-select {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    color: var(--color-text);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    padding: 0.5rem 0.75rem;
    cursor: pointer;
  }
  .backlog-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
    margin-top: var(--space-md);
  }
  .backlog-card {
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    transition: border-color var(--transition);
  }
  .backlog-card:hover {
    border-color: var(--color-accent);
  }
  .backlog-title-row {
    display: flex;
    align-items: baseline;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }
  .backlog-name {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-text);
    text-decoration: none;
  }
  .backlog-name:hover {
    color: var(--color-accent);
  }
  .backlog-hours {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-faint);
  }

  @media (min-width: 720px) {
    .backlog-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>

<script>
  // ---- Config ----
  const API_BASE = 'https://games-backend-production-d763.up.railway.app';
  const KEY_NAME = 'games_api_key';

  // ---- DOM refs ----
  const gateEl = document.getElementById('gate')!;
  const dashEl = document.getElementById('dashboard')!;
  const gateForm = document.getElementById('gate-form') as HTMLFormElement;
  const gateKey = document.getElementById('gate-key') as HTMLInputElement;
  const gateSubmit = document.getElementById('gate-submit') as HTMLButtonElement;
  const gateError = document.getElementById('gate-error')!;

  const syncStatusEl = document.getElementById('sync-status')!;
  const syncNowBtn = document.getElementById('sync-now') as HTMLButtonElement;
  const lockBtn = document.getElementById('lock-btn') as HTMLButtonElement;

  // ---- Taste profile ----
  const tasteToggle = document.getElementById('taste-toggle') as HTMLButtonElement;
  const tastePanel = document.getElementById('taste-panel')!;
  const tasteSummaryEl = document.getElementById('taste-summary')!;
  const tasteFavorites = document.getElementById('taste-favorites') as HTMLTextAreaElement;
  const tasteNotes = document.getElementById('taste-notes') as HTMLTextAreaElement;

  const PREFS_KEY = 'games_taste_prefs';

  function getPrefs(): { favoritesNote: string; values: string[]; notes: string } {
    try {
      const raw = localStorage.getItem(PREFS_KEY);
      return raw ? JSON.parse(raw) : { favoritesNote: '', values: [], notes: '' };
    } catch { return { favoritesNote: '', values: [], notes: '' }; }
  }

  function savePrefs() {
    const values = [...document.querySelectorAll<HTMLInputElement>('.taste-chip input:checked')].map((el) => el.value);
    const prefs = { favoritesNote: tasteFavorites.value.trim(), values, notes: tasteNotes.value.trim() };
    localStorage.setItem(PREFS_KEY, JSON.stringify(prefs));
    renderTasteSummary(prefs);
  }

  function renderTasteSummary(prefs: { favoritesNote: string; values: string[]; notes: string }) {
    const parts: string[] = [];
    if (prefs.favoritesNote) {
      const first3 = prefs.favoritesNote.split(',').slice(0, 3).map((s) => s.trim()).filter(Boolean).join(', ');
      if (first3) parts.push(first3);
    }
    if (prefs.values.length) parts.push(`${prefs.values.length} value${prefs.values.length === 1 ? '' : 's'} set`);
    tasteSummaryEl.textContent = parts.length
      ? parts.join(' · ') + ' ▾'
      : 'Not configured — tell Claude what you like ▾';
  }

  function loadPrefsIntoForm() {
    const prefs = getPrefs();
    tasteFavorites.value = prefs.favoritesNote || '';
    tasteNotes.value = prefs.notes || '';
    document.querySelectorAll<HTMLInputElement>('.taste-chip input').forEach((el) => {
      el.checked = prefs.values.includes(el.value);
    });
    renderTasteSummary(prefs);
  }

  tasteToggle.addEventListener('click', () => {
    const open = !tastePanel.hidden;
    tastePanel.hidden = open;
    tasteToggle.setAttribute('aria-expanded', String(!open));
  });
  tasteFavorites.addEventListener('input', savePrefs);
  tasteNotes.addEventListener('input', savePrefs);
  document.querySelectorAll<HTMLInputElement>('.taste-chip input').forEach((el) => el.addEventListener('change', savePrefs));

  const typeChips = document.getElementById('type-chips')!;
  const genreChips = document.getElementById('genre-chips')!;
  const platformChips = document.getElementById('platform-chips')!;
  const sinceInput = document.getElementById('since') as HTMLInputElement;
  const untilInput = document.getElementById('until') as HTMLInputElement;
  const applyBtn = document.getElementById('apply-filters') as HTMLButtonElement;

  const gridStatus = document.getElementById('grid-status')!;
  const grid = document.getElementById('releases-grid')!;
  const loadMoreBtn = document.getElementById('load-more') as HTMLButtonElement;

  // ---- State ----
  const state = {
    type: 'All',
    genre: 'All',
    platform: 'All',
    page: 1,
  };

  const TYPE_OPTIONS = [
    { value: 'All',           label: 'All' },
    { value: 'AAA',           label: 'AAA' },
    { value: 'indie',         label: 'Indie' },
    { value: 'early_access',  label: 'Early Access' },
    { value: 'multiplayer',   label: 'Multiplayer' },
    { value: 'single_player', label: 'Single Player' },
  ];
  const GENRE_OPTIONS = [
    { value: 'All',        label: 'All' },
    { value: 'action',     label: 'Action' },
    { value: 'rpg',        label: 'RPG' },
    { value: 'strategy',   label: 'Strategy' },
    { value: 'sports',     label: 'Sports' },
    { value: 'simulation', label: 'Simulation' },
  ];
  const PLATFORM_OPTIONS = [
    { value: 'All',             label: 'All' },
    { value: 'pc',              label: 'PC' },
    { value: 'playstation5',    label: 'PS5' },
    { value: 'playstation4',    label: 'PS4' },
    { value: 'xbox-series-x',   label: 'Xbox' },
    { value: 'nintendo-switch', label: 'Switch' },
  ];

  // ---- Helpers ----
  function getKey(): string | null {
    return sessionStorage.getItem(KEY_NAME);
  }

  function fmtDate(d: Date): string {
    return d.toISOString().slice(0, 10);
  }

  function relativeTime(iso: string | null | undefined): string {
    if (!iso) return 'never';
    const then = new Date(iso).getTime();
    if (Number.isNaN(then)) return 'unknown';
    const secs = Math.round((Date.now() - then) / 1000);
    const units: [number, string][] = [
      [60, 'second'],
      [60, 'minute'],
      [24, 'hour'],
      [Infinity, 'day'],
    ];
    let v = secs;
    let unit = 'second';
    for (let i = 0; i < units.length; i++) {
      unit = units[i][1];
      if (v < units[i][0]) break;
      v = Math.floor(v / units[i][0]);
    }
    const n = Math.max(v, 0);
    return `${n} ${unit}${n === 1 ? '' : 's'} ago`;
  }

  function escapeHtml(s: string): string {
    const div = document.createElement('div');
    div.textContent = s ?? '';
    return div.innerHTML;
  }

  // Centralized fetch that injects the auth header and handles 401.
  async function api(path: string, init: RequestInit = {}): Promise<any> {
    const key = getKey();
    if (!key) throw new Error('No access key');
    const res = await fetch(`${API_BASE}${path}`, {
      ...init,
      headers: {
        'x-api-secret': key,
        'Content-Type': 'application/json',
        ...(init.headers || {}),
      },
    });
    if (res.status === 401) {
      // Bad/expired key — drop it and bounce back to the gate.
      sessionStorage.removeItem(KEY_NAME);
      showGate('Access key rejected. Please try again.');
      throw new Error('Unauthorized');
    }
    if (!res.ok) {
      const body = await res.json().catch(() => null);
      throw new Error(body?.error || body?.warning || `Request failed (${res.status})`);
    }
    return res.json();
  }

  // ---- Gate ----
  function showGate(message?: string) {
    dashEl.hidden = true;
    gateEl.hidden = false;
    if (message) {
      gateError.textContent = message;
      gateError.hidden = false;
    } else {
      gateError.hidden = true;
    }
    gateKey.value = '';
    gateKey.focus();
  }

  function showDashboard() {
    gateEl.hidden = true;
    dashEl.hidden = false;
  }

  gateForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const key = gateKey.value.trim();
    if (!key) return;
    gateError.hidden = true;
    gateSubmit.disabled = true;
    gateSubmit.innerHTML = '<span class="spinner"></span> Checking…';
    try {
      // Validate the key against the backend before storing it.
      const res = await fetch(`${API_BASE}/health`, {
        headers: { 'x-api-secret': key },
      });
      if (res.status === 401) {
        gateError.textContent = 'Access key rejected. Please try again.';
        gateError.hidden = false;
        return;
      }
      if (!res.ok) {
        gateError.textContent = `Backend error (${res.status}). Try again later.`;
        gateError.hidden = false;
        return;
      }
      sessionStorage.setItem(KEY_NAME, key);
      showDashboard();
      initDashboard();
    } catch (err) {
      gateError.textContent = 'Could not reach the backend. Is it running?';
      gateError.hidden = false;
    } finally {
      gateSubmit.disabled = false;
      gateSubmit.textContent = 'Unlock';
    }
  });

  lockBtn.addEventListener('click', () => {
    sessionStorage.removeItem(KEY_NAME);
    showGate();
  });

  // ---- Sync status ----
  async function loadSyncStatus() {
    try {
      const data = await api('/steam/sync-status');
      syncStatusEl.textContent = `Steam library last synced ${relativeTime(data.lastSteamSync)}`;
      syncStatusEl.classList.toggle('stale', !!data.stale);
    } catch {
      syncStatusEl.textContent = 'Sync status unavailable';
    }
  }

  syncNowBtn.addEventListener('click', async () => {
    syncNowBtn.disabled = true;
    const original = syncNowBtn.textContent;
    syncNowBtn.innerHTML = '<span class="spinner"></span> Syncing…';
    try {
      await api('/steam/library/refresh', { method: 'POST' });
      await loadSyncStatus();
    } catch {
      syncStatusEl.textContent = 'Sync failed — try again';
      syncStatusEl.classList.add('stale');
    } finally {
      syncNowBtn.disabled = false;
      syncNowBtn.textContent = original;
    }
  });

  // ---- Filters UI ----
  function buildChips(
    container: HTMLElement,
    options: { value: string; label: string }[],
    groupKey: 'type' | 'genre' | 'platform',
  ) {
    container.innerHTML = '';
    options.forEach(({ value, label }) => {
      const chip = document.createElement('button');
      chip.type = 'button';
      chip.className = 'chip' + (state[groupKey] === value ? ' active' : '');
      chip.textContent = label;
      chip.addEventListener('click', () => {
        state[groupKey] = value;
        container.querySelectorAll('.chip').forEach((c) => c.classList.remove('active'));
        chip.classList.add('active');
        state.page = 1;
        loadReleases(false);
      });
      container.appendChild(chip);
    });
  }

  function setDefaultDates() {
    const now = new Date();
    const since = new Date(now);
    since.setDate(since.getDate() - 90);
    const until = new Date(now);
    until.setDate(until.getDate() + 90);
    sinceInput.value = fmtDate(since);
    untilInput.value = fmtDate(until);
  }

  applyBtn.addEventListener('click', () => {
    state.page = 1;
    loadReleases(false);
  });

  loadMoreBtn.addEventListener('click', () => {
    state.page += 1;
    loadReleases(true);
  });

  // ---- Releases ----
  function buildQuery(): string {
    const params = new URLSearchParams();
    const cats = [state.type, state.genre].filter((v) => v !== 'All').join(',');
    if (cats) params.set('categories', cats);
    if (state.platform !== 'All') params.set('platforms', state.platform);
    if (sinceInput.value) params.set('since', sinceInput.value);
    if (untilInput.value) params.set('until', untilInput.value);
    params.set('page', String(state.page));
    return params.toString();
  }

  async function loadReleases(append: boolean) {
    gridStatus.classList.remove('error');
    gridStatus.hidden = false;
    gridStatus.innerHTML = '<span class="spinner"></span> Loading releases…';
    if (!append) {
      grid.innerHTML = '';
      loadMoreBtn.hidden = true;
    }
    applyBtn.disabled = true;
    try {
      const data = await api(`/releases?${buildQuery()}`);
      const games = data.releases || [];
      if (!append && games.length === 0) {
        gridStatus.textContent = 'No releases match these filters.';
      } else {
        gridStatus.hidden = true;
      }
      games.forEach((g: any) => grid.appendChild(renderCard(g)));
      loadMoreBtn.hidden = !data.hasNext;
    } catch (err: any) {
      if (err?.message !== 'Unauthorized') {
        gridStatus.classList.add('error');
        gridStatus.hidden = false;
        gridStatus.textContent = `Could not load releases: ${err?.message || 'unknown error'}`;
      }
    } finally {
      applyBtn.disabled = false;
    }
  }

  function metacriticClass(score: number): string {
    if (score >= 75) return 'high';
    if (score >= 50) return 'mid';
    return 'low';
  }

  function renderCard(game: any): HTMLElement {
    const card = document.createElement('article');
    card.className = 'game-card';

    const platforms: string[] = Array.isArray(game.platforms) ? game.platforms : [];
    const platformText = platforms.slice(0, 6).map(escapeHtml).join(' · ');

    const mc =
      typeof game.metacriticScore === 'number' && game.metacriticScore > 0
        ? `<span class="metacritic ${metacriticClass(game.metacriticScore)}">${game.metacriticScore}</span>`
        : '';

    const releaseDate = game.releaseDate ? escapeHtml(game.releaseDate) : 'TBA';

    const byline = [game.developer, game.publisher]
      .filter(Boolean)
      .filter((v, i, a) => a.indexOf(v) === i)
      .join(' · ');

    const allCategories: string[] = Array.isArray(game.categories) && game.categories.length
      ? game.categories
      : game.category ? [game.category] : [];
    const categoriesText = allCategories.map(escapeHtml).join(' · ');

    card.innerHTML = `
      <h3>${escapeHtml(game.name || 'Untitled')}</h3>
      <div class="game-meta">
        <span>${releaseDate}</span>
        ${mc}
      </div>
      ${categoriesText ? `<p class="game-categories">${categoriesText}</p>` : ''}
      ${byline ? `<p class="game-byline">${escapeHtml(byline)}</p>` : ''}
      ${platformText ? `<p class="game-platforms">${platformText}</p>` : ''}
      ${game.description ? `<p class="game-desc">${escapeHtml(game.description)}</p>` : ''}
      <div class="card-actions">
        <button class="btn rate-btn" type="button">Rate this</button>
        ${game.steamAppId
          ? `<a class="steam-link" href="https://store.steampowered.com/app/${game.steamAppId}/" target="_blank" rel="noopener">Steam ↗</a>`
          : ''}
      </div>
      <div class="reco" hidden></div>
    `;

    const rateBtn = card.querySelector('.rate-btn') as HTMLButtonElement;
    const recoEl = card.querySelector('.reco') as HTMLElement;
    rateBtn.addEventListener('click', () => rate(game, rateBtn, recoEl));

    return card;
  }

  function confClass(score: number): { text: string; bg: string } {
    if (score >= 75) return { text: 'conf-high', bg: 'conf-high-bg' };
    if (score >= 50) return { text: 'conf-mid', bg: 'conf-mid-bg' };
    return { text: 'conf-low', bg: 'conf-low-bg' };
  }

  async function rate(game: any, btn: HTMLButtonElement, recoEl: HTMLElement) {
    const id = game.rawgId ?? game.id;
    if (id == null) return;
    btn.disabled = true;
    const original = btn.textContent;
    btn.innerHTML = '<span class="spinner"></span> Rating…';
    recoEl.hidden = false;
    recoEl.innerHTML = '<p class="reco-text"><span class="spinner"></span> Asking for a recommendation…</p>';
    try {
      const data = await api('/recommendations', {
        method: 'POST',
        body: JSON.stringify({ gameIds: [id], preferences: getPrefs() }),
      });
      const reco = (data.recommendations || [])[0];
      if (!reco) {
        recoEl.innerHTML = '<p class="reco-error">No recommendation returned.</p>';
        return;
      }
      const score = Math.max(0, Math.min(100, Math.round(reco.confidenceScore)));
      const cls = confClass(score);
      recoEl.innerHTML = `
        <div class="reco-head">
          <span class="reco-label">Confidence</span>
          <span class="reco-score ${cls.text}">${score}</span>
        </div>
        <div class="reco-bar"><span class="${cls.bg}" style="width:${score}%"></span></div>
        <p class="reco-text">${escapeHtml(reco.reasoning || '')}</p>
      `;
    } catch (err: any) {
      if (err?.message !== 'Unauthorized') {
        recoEl.innerHTML = `<p class="reco-error">Couldn't rate this: ${escapeHtml(err?.message || 'unknown error')}</p>`;
      }
    } finally {
      btn.disabled = false;
      btn.textContent = original;
    }
  }

  // ---- Backlog ----
  const backlogBtn = document.getElementById('backlog-btn') as HTMLButtonElement;
  const backlogStatus = document.getElementById('backlog-status')!;
  const backlogGrid = document.getElementById('backlog-grid')!;
  const backlogThreshold = document.getElementById('backlog-threshold') as HTMLSelectElement;

  const EXCLUDED_KEY = 'games_backlog_excluded';

  function getExcluded(): Set<number> {
    try {
      const raw = localStorage.getItem(EXCLUDED_KEY);
      return new Set(raw ? JSON.parse(raw) : []);
    } catch { return new Set(); }
  }

  function saveExcluded(ex: Set<number>) {
    localStorage.setItem(EXCLUDED_KEY, JSON.stringify([...ex]));
  }

  function updateExclusionNote() {
    const ex = getExcluded();
    let note = document.getElementById('backlog-exclusion-note');
    if (ex.size === 0) {
      note?.remove();
      return;
    }
    if (!note) {
      note = document.createElement('p');
      note.id = 'backlog-exclusion-note';
      note.className = 'grid-status mono backlog-exclusion-note';
      backlogGrid.parentElement!.insertBefore(note, backlogGrid);
    }
    note.innerHTML = `${ex.size} game${ex.size === 1 ? '' : 's'} excluded · <button class="inline-link" id="backlog-reset">Reset</button>`;
    document.getElementById('backlog-reset')?.addEventListener('click', () => {
      localStorage.removeItem(EXCLUDED_KEY);
      note!.remove();
    });
  }

  function renderBacklogCard(pick: any): HTMLElement {
    const card = document.createElement('article');
    card.className = 'backlog-card';
    const score = Math.max(0, Math.min(100, Math.round(pick.confidenceScore ?? 0)));
    const cls = confClass(score);
    const hours = pick.hoursPlayed ?? 0;
    card.innerHTML = `
      <div class="backlog-title-row">
        <a class="backlog-name" href="https://store.steampowered.com/app/${pick.appId}/" target="_blank" rel="noopener">${escapeHtml(pick.name || 'Unknown')} ↗</a>
        <span class="backlog-hours">${hours}h played</span>
        <button class="backlog-exclude" type="button" title="Exclude from future picks">✕ Exclude</button>
      </div>
      <div class="reco-head">
        <span class="reco-label">Confidence</span>
        <span class="reco-score ${cls.text}">${score}</span>
      </div>
      <div class="reco-bar"><span class="${cls.bg}" style="width:${score}%"></span></div>
      <p class="reco-text">${escapeHtml(pick.reasoning || '')}</p>
    `;
    card.querySelector('.backlog-exclude')!.addEventListener('click', () => {
      const ex = getExcluded();
      ex.add(pick.appId);
      saveExcluded(ex);
      card.remove();
      updateExclusionNote();
    });
    return card;
  }

  async function loadBacklogPicks() {
    const threshold = backlogThreshold.value;
    const excluded = [...getExcluded()];
    const excludeParam = excluded.length ? `&exclude=${excluded.join(',')}` : '';
    backlogStatus.hidden = false;
    backlogStatus.classList.remove('error');
    backlogStatus.innerHTML = '<span class="spinner"></span> Finding picks from your backlog…';
    backlogGrid.innerHTML = '';
    backlogBtn.disabled = true;
    try {
      const data = await api(`/steam/backlog-picks?threshold=${threshold}&limit=5${excludeParam}`, {
        method: 'POST',
        body: JSON.stringify({ preferences: getPrefs() }),
      });
      const picks: any[] = data.picks ?? [];
      if (picks.length === 0) {
        backlogStatus.textContent = data.warning ?? 'No picks found.';
        return;
      }
      const count = data.candidateCount ?? picks.length;
      backlogStatus.textContent = `Top picks from ${count} games with < ${threshold}h played`;
      backlogStatus.hidden = false;
      picks.forEach((p) => backlogGrid.appendChild(renderBacklogCard(p)));
      updateExclusionNote();
    } catch (err: any) {
      if (err?.message !== 'Unauthorized') {
        backlogStatus.classList.add('error');
        backlogStatus.hidden = false;
        backlogStatus.textContent = `Couldn't load picks: ${err?.message || 'unknown error'}`;
      }
    } finally {
      backlogBtn.disabled = false;
    }
  }

  backlogBtn.addEventListener('click', loadBacklogPicks);

  // ---- Init ----
  function initDashboard() {
    loadPrefsIntoForm();
    buildChips(typeChips, TYPE_OPTIONS, 'type');
    buildChips(genreChips, GENRE_OPTIONS, 'genre');
    buildChips(platformChips, PLATFORM_OPTIONS, 'platform');
    setDefaultDates();
    loadSyncStatus();
    loadReleases(false);
  }

  // ---- Boot ----
  if (getKey()) {
    showDashboard();
    initDashboard();
  } else {
    showGate();
  }
</script>
