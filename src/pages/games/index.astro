---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteNav from '../../components/SiteNav.astro';
---

<BaseLayout
  title="Games — Devon Troedel"
  description="Private games dashboard."
>
  <div id="site">
    <div id="bg-grid" aria-hidden="true"></div>

    <SiteNav />

    <div class="page-content">

      <!-- ── Access gate ── -->
      <section id="gate" class="gate-wrap" hidden>
        <div class="gate-outer">
          <div class="gate-glow" aria-hidden="true"></div>
          <div class="gate-card">
            <div class="gate-titlebar">
              <span class="dot-orange"></span>
              <span class="dot-dim"></span>
              <span class="dot-dim"></span>
              <span class="gate-card-label">// access required · games</span>
            </div>
            <div class="gate-body">
              <div class="gate-query" aria-hidden="true">
                <span class="kw">SELECT</span> <span class="col">*</span>
                <span class="kw">FROM</span> <span class="tbl">sessions</span>
                <span class="kw">WHERE</span> <span class="col">api_key</span> = <span class="val">?</span>;
              </div>
              <p class="gate-intro">Enter the access key to unlock the dashboard.</p>
              <form id="gate-form" class="gate-form" autocomplete="off">
                <input
                  id="gate-key"
                  type="password"
                  class="gate-input"
                  placeholder="Access key"
                  aria-label="Access key"
                  required
                />
                <button type="submit" id="gate-submit" class="btn-primary">Unlock</button>
              </form>
              <p id="gate-error" class="gate-error" role="alert" hidden></p>
            </div>
          </div>
        </div>
      </section>

      <!-- ── Dashboard ── -->
      <section id="dashboard" class="dashboard" hidden>

        <div class="page-head">
          <div class="eyebrow-amber">// games</div>
          <h1 class="page-h1">Game recommendations</h1>
        </div>

        <!-- Sync bar -->
        <div class="sync-bar">
          <span class="sync-dot" aria-hidden="true"></span>
          <span id="sync-status" class="sync-status">Loading sync status…</span>
          <div class="sync-actions">
            <button id="sync-now" class="btn-sm" type="button">Sync now</button>
          </div>
        </div>

        <!-- Taste profile -->
        <div class="taste-section">
          <button id="taste-toggle" class="taste-toggle" type="button" aria-expanded="false">
            <span class="taste-label">// taste profile</span>
            <span id="taste-summary" class="taste-summary">Not configured — tell Claude what you like</span>
            <span class="taste-chevron" aria-hidden="true">▾</span>
          </button>
          <div id="taste-panel" class="taste-panel" hidden>
            <div class="taste-field">
              <label class="field-label" for="taste-favorites">Favorites not on Steam (or where hours don't reflect how much you love them)</label>
              <textarea id="taste-favorites" class="taste-textarea" rows="2" placeholder="e.g. Tales of Arise, FFXIV, Kingdom Hearts, FFX, Chained Echoes, Dark Souls, WoW…"></textarea>
            </div>
            <div class="taste-field">
              <span class="field-label">What matters most to you in a game</span>
              <div class="taste-values">
                <label class="taste-chip"><input type="checkbox" value="story" hidden> Story &amp; Narrative</label>
                <label class="taste-chip"><input type="checkbox" value="build-depth" hidden> Build Depth &amp; Systems</label>
                <label class="taste-chip"><input type="checkbox" value="combat" hidden> Combat Feel</label>
                <label class="taste-chip"><input type="checkbox" value="exploration" hidden> World Exploration</label>
                <label class="taste-chip"><input type="checkbox" value="lore" hidden> Lore &amp; World-building</label>
                <label class="taste-chip"><input type="checkbox" value="social" hidden> MMO / Social</label>
                <label class="taste-chip"><input type="checkbox" value="emotional" hidden> Emotional Impact</label>
                <label class="taste-chip"><input type="checkbox" value="mechanics" hidden> Unique Mechanics</label>
                <label class="taste-chip"><input type="checkbox" value="fantasy" hidden> Fantasy Setting</label>
              </div>
            </div>
            <div class="taste-field">
              <label class="field-label" for="taste-notes">Anything else Claude should know</label>
              <textarea id="taste-notes" class="taste-textarea" rows="2" placeholder="e.g. FFXII for the Gambit system and job builds, not the story. I value deep MMO worlds but not necessarily the grind."></textarea>
            </div>
          </div>
        </div>

        <!-- Tabs -->
        <nav class="tab-nav">
          <button class="tab-btn active" data-tab="own" type="button">// own</button>
          <button class="tab-btn" data-tab="discover" type="button">// discover</button>
          <button class="tab-btn" data-tab="lookup" type="button">// lookup</button>
        </nav>

        <!-- Own tab -->
        <div class="tab-content" data-tab="own">
          <p class="tab-desc">Top picks from games you already own but haven't really played.</p>
          <div class="backlog-controls">
            <span class="field-label">Games with less than</span>
            <select id="backlog-threshold" class="g-select">
              <option value="2">2h played</option>
              <option value="5" selected>5h played</option>
              <option value="10">10h played</option>
              <option value="20">20h played</option>
            </select>
            <button id="backlog-btn" class="btn-primary" type="button">Find picks</button>
          </div>
          <p id="backlog-status" class="grid-status" hidden></p>
          <div id="backlog-grid" class="result-grid"></div>
        </div>

        <!-- Discover tab -->
        <div class="tab-content" data-tab="discover" hidden>
          <p class="tab-desc">Games you don't own yet, matched to your taste profile.</p>
          <div class="discover-filters">
            <div class="filter-group">
              <span class="field-label">Platform</span>
              <div class="chips" id="discover-platform-chips"></div>
            </div>
            <div class="filter-group">
              <span class="field-label">Genre</span>
              <div class="chips" id="discover-genre-chips"></div>
            </div>
          </div>
          <div class="discover-actions">
            <button id="discover-btn" class="btn-primary" type="button">Find recommendations</button>
            <button id="browse-toggle" class="btn-secondary" type="button">Browse upcoming releases ▾</button>
          </div>
          <p id="discover-status" class="grid-status" hidden></p>
          <div id="discover-grid" class="result-grid"></div>

          <!-- Upcoming releases browser -->
          <div id="browse-section" hidden>
            <div class="browse-head">
              <div class="eyebrow-amber">// upcoming releases</div>
            </div>
            <div class="browse-filters">
              <div class="filter-group">
                <span class="field-label">Type</span>
                <div class="chips" id="type-chips"></div>
              </div>
              <div class="filter-group dates">
                <label class="date-field">
                  <span class="field-label">Since</span>
                  <input type="date" id="since" class="g-input date-input" />
                </label>
                <label class="date-field">
                  <span class="field-label">Until</span>
                  <input type="date" id="until" class="g-input date-input" />
                </label>
                <button id="apply-filters" class="btn-primary apply-btn" type="button">Apply</button>
              </div>
            </div>
            <p id="grid-status" class="grid-status" hidden></p>
            <div id="releases-grid" class="releases-grid"></div>
            <div class="grid-foot">
              <button id="load-more" class="btn-secondary" type="button" hidden>Load more</button>
            </div>
          </div>
        </div>

        <!-- Lookup tab -->
        <div class="tab-content" data-tab="lookup" hidden>
          <p class="tab-desc">Score a specific game, or describe what you're looking for.</p>
          <div class="lookup-form">
            <input
              id="lookup-input"
              type="text"
              class="g-input lookup-input"
              placeholder="e.g. Metaphor: ReFantazio  ·  games like Chained Echoes with deep build systems"
            />
            <button id="lookup-btn" class="btn-primary" type="button">Search</button>
          </div>
          <p id="lookup-status" class="grid-status" hidden></p>
          <div id="lookup-grid" class="result-grid"></div>
        </div>

      <div class="key-strip">
        <span class="key-strip-label">🔐 access key saved on this device</span>
        <button id="lock-btn" class="btn-sm btn-dim" type="button">lock</button>
      </div>

      </section><!-- #dashboard -->

    </div><!-- .page-content -->
  </div><!-- #site -->
</BaseLayout>

<!-- Global styles: dynamically-created elements need global scope -->
<style is:global>
  /* ── Filter chips (built by buildChips()) ── */
  .chip {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: #9aa6c2;
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    padding: 6px 13px;
    cursor: pointer;
    transition: color 0.15s, background 0.15s, border-color 0.15s;
  }
  .chip:hover {
    color: #e9edf7;
    border-color: rgba(255, 255, 255, 0.2);
  }
  .chip.active {
    color: #2dd4bf;
    background: color-mix(in srgb, #2dd4bf 10%, transparent);
    border-color: color-mix(in srgb, #2dd4bf 40%, transparent);
    font-weight: 600;
  }

  /* ── Backlog / discover / lookup cards ── */
  .backlog-card,
  .discover-card {
    background: #0e1424;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 14px;
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    transition: border-color 0.2s, transform 0.2s;
  }
  .backlog-card:hover,
  .discover-card:hover {
    border-color: color-mix(in srgb, #2dd4bf 35%, transparent);
    transform: translateY(-3px);
  }

  .backlog-title-row {
    display: flex;
    align-items: baseline;
    gap: 10px;
    flex-wrap: wrap;
  }
  .backlog-name {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 16px;
    font-weight: 600;
    color: #f4f7fd;
    text-decoration: none;
    transition: color 0.15s;
  }
  .backlog-name:hover { color: #2dd4bf; }
  .backlog-hours {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: #616d8c;
  }

  .discover-name {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 16px;
    font-weight: 600;
    color: #f4f7fd;
    display: block;
  }
  .discover-platforms {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: #616d8c;
    display: block;
    margin-top: 3px;
  }

  .backlog-exclude {
    margin-left: auto;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: #616d8c;
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 6px;
    padding: 3px 9px;
    cursor: pointer;
    transition: color 0.15s, border-color 0.15s;
    white-space: nowrap;
  }
  .backlog-exclude:hover { color: #f87171; border-color: #f87171; }

  .inline-link {
    background: none;
    border: none;
    padding: 0;
    color: #2dd4bf;
    font-family: 'JetBrains Mono', monospace;
    font-size: inherit;
    cursor: pointer;
    text-decoration: underline;
  }
  .inline-link:hover { color: #7ee0d0; }
  .backlog-exclusion-note { margin-bottom: 0; }

  /* ── Release browser game cards ── */
  .game-card {
    background: #0e1424;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 14px;
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    transition: border-color 0.2s, transform 0.2s;
  }
  .game-card:hover {
    border-color: color-mix(in srgb, #2dd4bf 35%, transparent);
    transform: translateY(-3px);
  }
  .game-card h3 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 17px;
    font-weight: 600;
    color: #f4f7fd;
    margin: 0;
  }
  .game-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 6px 10px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: #9aa6c2;
  }
  .metacritic {
    font-weight: 700;
    font-size: 11px;
    color: #0a0e1a;
    background: #9aa6c2;
    border-radius: 5px;
    padding: 2px 7px;
  }
  .metacritic.high { background: #22c55e; }
  .metacritic.mid  { background: #f59e0b; }
  .metacritic.low  { background: #ef4444; }
  .game-platforms  { font-family: 'JetBrains Mono', monospace; font-size: 11px; color: #616d8c; margin: 0; }
  .game-categories { font-family: 'JetBrains Mono', monospace; font-size: 11px; color: #2dd4bf; text-transform: uppercase; letter-spacing: 0.04em; margin: 0; }
  .game-byline     { font-family: 'JetBrains Mono', monospace; font-size: 11px; color: #616d8c; margin: 0; }
  .game-desc {
    font-size: 14px;
    color: #9aa6c2;
    line-height: 1.55;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card-actions {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: auto;
    flex-wrap: wrap;
  }
  .rate-btn {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    font-weight: 500;
    padding: 6px 13px;
    border-radius: 8px;
    border: 1px solid color-mix(in srgb, #2dd4bf 35%, transparent);
    background: color-mix(in srgb, #2dd4bf 8%, transparent);
    color: #7ee0d0;
    cursor: pointer;
    transition: background 0.2s;
  }
  .rate-btn:hover { background: color-mix(in srgb, #2dd4bf 16%, transparent); }
  .steam-link {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: #616d8c;
    text-decoration: none;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 7px;
    padding: 6px 12px;
    transition: color 0.15s, border-color 0.15s;
  }
  .steam-link:hover { color: #2dd4bf; border-color: color-mix(in srgb, #2dd4bf 35%, transparent); }

  /* ── Confidence bars ── */
  .reco {
    border-top: 1px solid rgba(255, 255, 255, 0.07);
    padding-top: 12px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .reco-head {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .reco-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: #616d8c;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .reco-score {
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    font-weight: 700;
  }
  .reco-bar {
    height: 5px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.06);
    overflow: hidden;
  }
  .reco-bar > span {
    display: block;
    height: 100%;
    border-radius: 999px;
    transition: width 0.4s ease;
  }
  .conf-high    { color: #2dd4bf; }
  .conf-high-bg { background: #2dd4bf; }
  .conf-mid     { color: #f0a868; }
  .conf-mid-bg  { background: #f0a868; }
  .conf-low     { color: #9aa6c2; }
  .conf-low-bg  { background: #9aa6c2; }
  .reco-text  { font-size: 13.5px; color: #9aa6c2; line-height: 1.55; margin: 0; }
  .reco-error { font-size: 13.5px; color: #f87171; margin: 0; }

  /* ── Spinner ── */
  .spinner {
    display: inline-block;
    width: 0.85em;
    height: 0.85em;
    border: 2px solid currentColor;
    border-right-color: transparent;
    border-radius: 50%;
    animation: g-spin 0.6s linear infinite;
    vertical-align: -0.1em;
  }
  @keyframes g-spin { to { transform: rotate(360deg); } }
  button[disabled] { opacity: 0.55; cursor: progress; }

  /* ── Key strip ── */
  .key-strip { display: flex; align-items: center; justify-content: space-between; padding: 10px 0; border-top: 1px solid rgba(255,255,255,0.06); margin-top: 32px; opacity: 0.45; transition: opacity 0.18s; }
  .key-strip:hover { opacity: 0.85; }
  .key-strip-label { font-family: 'JetBrains Mono', monospace; font-size: 11px; color: #616d8c; }
</style>

<style>
  /* ── Site shell (matches homepage tokens) ── */
  #site {
    --ac: #2dd4bf;
    --ac-lite: #5fe6d4;
    --ac-soft: #7ee0d0;
    position: relative;
    min-height: 100vh;
    background:
      radial-gradient(900px 480px at 78% -8%, color-mix(in srgb, var(--ac) 10%, transparent), transparent 60%),
      radial-gradient(700px 420px at 8% 8%, rgba(240, 168, 104, 0.06), transparent 60%),
      #0a0e1a;
    overflow-x: clip; /* `clip` keeps the sticky nav working; `hidden` would break it */
  }

  #bg-grid {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    opacity: 0.5;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.022) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.022) 1px, transparent 1px);
    background-size: 64px 64px;
  }

  /* ── Page content ── */
  .page-content {
    position: relative;
    z-index: 1;
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 28px 80px;
  }

  /* ── Gate ── */
  .gate-wrap {
    min-height: calc(100vh - 56px);
    display: grid;
    place-items: center;
    padding: 60px 0;
  }

  .gate-outer {
    position: relative;
    width: 100%;
    max-width: 440px;
  }

  .gate-glow {
    position: absolute;
    inset: -1px;
    border-radius: 16px;
    background: linear-gradient(
      150deg,
      color-mix(in srgb, var(--ac) 45%, transparent),
      rgba(240, 168, 104, 0.25),
      transparent 70%
    );
    opacity: 0.7;
    filter: blur(0.5px);
  }

  .gate-card {
    position: relative;
    border-radius: 15px;
    background: #0d1322;
    border: 1px solid rgba(255, 255, 255, 0.1);
    overflow: hidden;
    box-shadow: 0 30px 70px -28px rgba(0, 0, 0, 0.8);
  }

  .gate-titlebar {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 13px 16px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
    background: rgba(255, 255, 255, 0.015);
  }

  .dot-orange {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: #f0a868;
    flex-shrink: 0;
  }

  .dot-dim {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.16);
    flex-shrink: 0;
  }

  .gate-card-label {
    margin-left: 8px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: #616d8c;
  }

  .gate-body {
    padding: 24px;
  }

  .gate-query {
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    margin-bottom: 20px;
    padding: 14px 16px;
    background: rgba(255, 255, 255, 0.025);
    border-radius: 8px;
    border: 1px solid rgba(255, 255, 255, 0.06);
    line-height: 1.6;
  }

  .kw  { color: #f0a868; }
  .col { color: #cdd5e8; }
  .tbl { color: var(--ac); }
  .val { color: var(--ac-soft); }

  .gate-intro {
    font-size: 14.5px;
    color: #9aa6c2;
    margin: 0 0 18px;
  }

  .gate-form {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .gate-input {
    flex: 1 1 12rem;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 9px;
    color: #e9edf7;
    font-family: 'JetBrains Mono', monospace;
    font-size: 14px;
    padding: 10px 14px;
    transition: border-color 0.2s;
  }

  .gate-input:focus {
    outline: none;
    border-color: color-mix(in srgb, var(--ac) 60%, transparent);
  }

  .gate-error {
    color: #f87171;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12.5px;
    margin-top: 12px;
  }

  /* ── Shared buttons ── */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 10px 18px;
    border-radius: 9px;
    border: none;
    background: var(--ac);
    color: #0a0e1a;
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    text-decoration: none;
    transition: background 0.2s;
    white-space: nowrap;
  }
  .btn-primary:hover { background: var(--ac-lite); }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 10px 18px;
    border-radius: 9px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: transparent;
    color: #cdd5e8;
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s;
    white-space: nowrap;
  }
  .btn-secondary:hover {
    border-color: color-mix(in srgb, var(--ac) 50%, transparent);
    color: #fff;
  }

  .btn-sm {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11.5px;
    font-weight: 500;
    padding: 6px 13px;
    border-radius: 7px;
    border: 1px solid color-mix(in srgb, var(--ac) 35%, transparent);
    background: color-mix(in srgb, var(--ac) 8%, transparent);
    color: var(--ac-soft);
    cursor: pointer;
    transition: background 0.2s;
    white-space: nowrap;
  }
  .btn-sm:hover { background: color-mix(in srgb, var(--ac) 16%, transparent); }

  .btn-dim {
    border-color: rgba(255, 255, 255, 0.1);
    background: transparent;
    color: #616d8c;
  }
  .btn-dim:hover {
    background: rgba(255, 255, 255, 0.04);
    border-color: rgba(255, 255, 255, 0.18);
    color: #9aa6c2;
  }

  /* ── Shared inputs/selects ── */
  .g-input,
  .g-select {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 9px;
    color: #e9edf7;
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
