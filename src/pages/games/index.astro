---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout
  title="Games — Devon Troedel"
  description="Private games dashboard."
>
  <Header />
  <main>
    <!-- Access gate: shown until a key is stored in sessionStorage -->
    <section id="gate" class="gate" hidden>
      <div class="gate-card">
        <p class="eyebrow mono">// private</p>
        <h1>Games dashboard</h1>
        <p class="gate-intro">
          This page is password-gated. Enter the access key to continue.
        </p>
        <form id="gate-form" class="gate-form" autocomplete="off">
          <input
            id="gate-key"
            type="password"
            class="gate-input"
            placeholder="Access key"
            aria-label="Access key"
            required
          />
          <button type="submit" class="btn btn-primary" id="gate-submit">Unlock</button>
        </form>
        <p id="gate-error" class="gate-error" role="alert" hidden></p>
      </div>
    </section>

    <!-- Dashboard: populated by JS once authenticated -->
    <section id="dashboard" class="dashboard" hidden>
      <div class="page-head">
        <p class="eyebrow mono">// games</p>
        <h1>Game releases</h1>
      </div>

      <!-- Sync status bar -->
      <div class="sync-bar">
        <span id="sync-status" class="sync-status mono">Loading sync status…</span>
        <button id="sync-now" class="btn sync-btn" type="button">Sync now</button>
        <button id="lock-btn" class="btn lock-btn" type="button" title="Forget access key">Lock</button>
      </div>

      <!-- Filter bar -->
      <div class="filters">
        <div class="filter-group" data-group="category">
          <span class="filter-label mono">Category</span>
          <div class="chips" id="category-chips"></div>
        </div>
        <div class="filter-group" data-group="platform">
          <span class="filter-label mono">Platform</span>
          <div class="chips" id="platform-chips"></div>
        </div>
        <div class="filter-group dates">
          <label class="date-field">
            <span class="filter-label mono">Since</span>
            <input type="date" id="since" class="date-input" />
          </label>
          <label class="date-field">
            <span class="filter-label mono">Until</span>
            <input type="date" id="until" class="date-input" />
          </label>
          <button id="apply-filters" class="btn btn-primary apply-btn" type="button">Apply</button>
        </div>
      </div>

      <!-- Results -->
      <p id="grid-status" class="grid-status mono" hidden></p>
      <div id="releases-grid" class="releases-grid"></div>
      <div class="grid-foot">
        <button id="load-more" class="btn" type="button" hidden>Load more</button>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  /* ---- Access gate ---- */
  .gate {
    min-height: 60vh;
    display: grid;
    place-items: center;
    padding-block: var(--space-2xl);
  }
  .gate-card {
    width: 100%;
    max-width: 28rem;
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: var(--space-lg);
    box-shadow: var(--shadow);
  }
  .gate-intro {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    margin-top: var(--space-sm);
  }
  .gate-form {
    display: flex;
    gap: var(--space-sm);
    margin-top: var(--space-md);
    flex-wrap: wrap;
  }
  .gate-input,
  .date-input {
    flex: 1 1 12rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    color: var(--color-text);
    font-family: var(--font-mono);
    font-size: 0.95rem;
    padding: 0.7rem 0.9rem;
  }
  .gate-input:focus,
  .date-input:focus {
    outline: 2px solid var(--color-accent);
    outline-offset: 1px;
  }
  .gate-error {
    color: #f87171;
    font-size: 0.9rem;
    margin-top: var(--space-sm);
  }

  /* ---- Page head ---- */
  .page-head {
    padding-block: var(--space-xl) var(--space-md);
  }
  .eyebrow {
    color: var(--color-accent);
    font-size: 0.9rem;
    letter-spacing: 0.04em;
    margin-bottom: var(--space-xs);
  }

  /* ---- Sync bar ---- */
  .sync-bar {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    flex-wrap: wrap;
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: var(--space-sm) var(--space-md);
  }
  .sync-status {
    flex: 1 1 auto;
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }
  .sync-status.stale {
    color: #f59e0b;
  }
  .sync-btn,
  .lock-btn {
    font-size: 0.8rem;
    padding: 0.45rem 0.9rem;
  }
  .lock-btn {
    border-color: var(--color-border);
    color: var(--color-text-muted);
  }

  /* ---- Filters ---- */
  .filters {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    margin-top: var(--space-md);
    padding: var(--space-md);
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
  }
  .filter-group {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }
  .filter-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-faint);
  }
  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }
  .chip {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 0.3rem 0.85rem;
    cursor: pointer;
    transition: all var(--transition);
  }
  .chip:hover {
    color: var(--color-text);
    border-color: var(--color-accent);
  }
  .chip.active {
    color: var(--color-accent);
    background: var(--color-accent-soft);
    border-color: var(--color-accent);
  }
  .dates {
    gap: var(--space-md);
  }
  .date-field {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .date-input {
    flex: 0 1 auto;
  }
  .apply-btn {
    align-self: flex-end;
    font-size: 0.85rem;
    padding: 0.55rem 1.1rem;
  }

  /* ---- Grid ---- */
  .grid-status {
    margin-top: var(--space-md);
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }
  .grid-status.error {
    color: #f87171;
  }
  .releases-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
    margin-top: var(--space-md);
  }
  .game-card {
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    transition: border-color var(--transition), transform var(--transition);
  }
  .game-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
  }
  .game-card h3 {
    font-size: 1.1rem;
  }
  .game-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-xs) var(--space-sm);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }
  .metacritic {
    font-weight: 700;
    color: var(--color-bg);
    background: var(--color-text-muted);
    border-radius: var(--radius-sm);
    padding: 0.1rem 0.5rem;
  }
  .metacritic.high { background: #22c55e; }
  .metacritic.mid { background: #f59e0b; }
  .metacritic.low { background: #ef4444; }
  .platforms {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }
  .platform-badge {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 0.1rem 0.45rem;
  }
  .game-desc {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card-actions {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-top: auto;
  }
  .rate-btn {
    font-size: 0.8rem;
    padding: 0.45rem 0.9rem;
  }

  /* ---- Recommendation result ---- */
  .reco {
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-sm);
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }
  .reco-head {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }
  .reco-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-faint);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .reco-score {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 700;
  }
  .reco-bar {
    height: 6px;
    border-radius: 999px;
    background: var(--color-surface);
    overflow: hidden;
  }
  .reco-bar > span {
    display: block;
    height: 100%;
    border-radius: 999px;
    transition: width var(--transition);
  }
  .conf-high  { color: var(--color-accent); }
  .conf-high-bg  { background: var(--color-accent); }
  .conf-mid   { color: #f59e0b; }
  .conf-mid-bg   { background: #f59e0b; }
  .conf-low   { color: var(--color-text-muted); }
  .conf-low-bg   { background: var(--color-text-muted); }
  .reco-text {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    line-height: 1.55;
  }
  .reco-error {
    font-size: 0.85rem;
    color: #f87171;
  }

  .grid-foot {
    display: flex;
    justify-content: center;
    margin-top: var(--space-lg);
  }

  /* spinner for loading states */
  .spinner {
    display: inline-block;
    width: 0.85em;
    height: 0.85em;
    border: 2px solid currentColor;
    border-right-color: transparent;
    border-radius: 50%;
    animation: spin 0.6s linear infinite;
    vertical-align: -0.1em;
  }
  @keyframes spin { to { transform: rotate(360deg); } }
  button[disabled] { opacity: 0.6; cursor: progress; }

  @media (min-width: 720px) {
    .releases-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>

<script>
  // ---- Config ----
  const API_BASE = 'https://games-backend-production-d763.up.railway.app';
  const KEY_NAME = 'games_api_key';

  // ---- DOM refs ----
  const gateEl = document.getElementById('gate')!;
  const dashEl = document.getElementById('dashboard')!;
  const gateForm = document.getElementById('gate-form') as HTMLFormElement;
  const gateKey = document.getElementById('gate-key') as HTMLInputElement;
  const gateSubmit = document.getElementById('gate-submit') as HTMLButtonElement;
  const gateError = document.getElementById('gate-error')!;

  const syncStatusEl = document.getElementById('sync-status')!;
  const syncNowBtn = document.getElementById('sync-now') as HTMLButtonElement;
  const lockBtn = document.getElementById('lock-btn') as HTMLButtonElement;

  const categoryChips = document.getElementById('category-chips')!;
  const platformChips = document.getElementById('platform-chips')!;
  const sinceInput = document.getElementById('since') as HTMLInputElement;
  const untilInput = document.getElementById('until') as HTMLInputElement;
  const applyBtn = document.getElementById('apply-filters') as HTMLButtonElement;

  const gridStatus = document.getElementById('grid-status')!;
  const grid = document.getElementById('releases-grid')!;
  const loadMoreBtn = document.getElementById('load-more') as HTMLButtonElement;

  // ---- State ----
  const state = {
    category: 'All',
    platform: 'All',
    page: 1,
  };

  const CATEGORIES = ['All', 'AAA', 'Indie', 'Early Access', 'Multiplayer', 'Single Player'];
  const PLATFORMS = ['All', 'Steam', 'PC', 'Console'];

  // ---- Helpers ----
  function getKey(): string | null {
    return sessionStorage.getItem(KEY_NAME);
  }

  function fmtDate(d: Date): string {
    return d.toISOString().slice(0, 10);
  }

  function relativeTime(iso: string | null | undefined): string {
    if (!iso) return 'never';
    const then = new Date(iso).getTime();
    if (Number.isNaN(then)) return 'unknown';
    const secs = Math.round((Date.now() - then) / 1000);
    const units: [number, string][] = [
      [60, 'second'],
      [60, 'minute'],
      [24, 'hour'],
      [Infinity, 'day'],
    ];
    let v = secs;
    let unit = 'second';
    for (let i = 0; i < units.length; i++) {
      unit = units[i][1];
      if (v < units[i][0]) break;
      v = Math.floor(v / units[i][0]);
    }
    const n = Math.max(v, 0);
    return `${n} ${unit}${n === 1 ? '' : 's'} ago`;
  }

  function escapeHtml(s: string): string {
    const div = document.createElement('div');
    div.textContent = s ?? '';
    return div.innerHTML;
  }

  // Centralized fetch that injects the auth header and handles 401.
  async function api(path: string, init: RequestInit = {}): Promise<any> {
    const key = getKey();
    if (!key) throw new Error('No access key');
    const res = await fetch(`${API_BASE}${path}`, {
      ...init,
      headers: {
        'x-api-secret': key,
        'Content-Type': 'application/json',
        ...(init.headers || {}),
      },
    });
    if (res.status === 401) {
      // Bad/expired key — drop it and bounce back to the gate.
      sessionStorage.removeItem(KEY_NAME);
      showGate('Access key rejected. Please try again.');
      throw new Error('Unauthorized');
    }
    if (!res.ok) {
      throw new Error(`Request failed (${res.status})`);
    }
    return res.json();
  }

  // ---- Gate ----
  function showGate(message?: string) {
    dashEl.hidden = true;
    gateEl.hidden = false;
    if (message) {
      gateError.textContent = message;
      gateError.hidden = false;
    } else {
      gateError.hidden = true;
    }
    gateKey.value = '';
    gateKey.focus();
  }

  function showDashboard() {
    gateEl.hidden = true;
    dashEl.hidden = false;
  }

  gateForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const key = gateKey.value.trim();
    if (!key) return;
    gateError.hidden = true;
    gateSubmit.disabled = true;
    gateSubmit.innerHTML = '<span class="spinner"></span> Checking…';
    try {
      // Validate the key against the backend before storing it.
      const res = await fetch(`${API_BASE}/health`, {
        headers: { 'x-api-secret': key },
      });
      if (res.status === 401) {
        gateError.textContent = 'Access key rejected. Please try again.';
        gateError.hidden = false;
        return;
      }
      if (!res.ok) {
        gateError.textContent = `Backend error (${res.status}). Try again later.`;
        gateError.hidden = false;
        return;
      }
      sessionStorage.setItem(KEY_NAME, key);
      showDashboard();
      initDashboard();
    } catch (err) {
      gateError.textContent = 'Could not reach the backend. Is it running?';
      gateError.hidden = false;
    } finally {
      gateSubmit.disabled = false;
      gateSubmit.textContent = 'Unlock';
    }
  });

  lockBtn.addEventListener('click', () => {
    sessionStorage.removeItem(KEY_NAME);
    showGate();
  });

  // ---- Sync status ----
  async function loadSyncStatus() {
    try {
      const data = await api('/steam/sync-status');
      syncStatusEl.textContent = `Steam library last synced ${relativeTime(data.lastSteamSync)}`;
      syncStatusEl.classList.toggle('stale', !!data.stale);
    } catch {
      syncStatusEl.textContent = 'Sync status unavailable';
    }
  }

  syncNowBtn.addEventListener('click', async () => {
    syncNowBtn.disabled = true;
    const original = syncNowBtn.textContent;
    syncNowBtn.innerHTML = '<span class="spinner"></span> Syncing…';
    try {
      await api('/steam/library/refresh', { method: 'POST' });
      await loadSyncStatus();
    } catch {
      syncStatusEl.textContent = 'Sync failed — try again';
      syncStatusEl.classList.add('stale');
    } finally {
      syncNowBtn.disabled = false;
      syncNowBtn.textContent = original;
    }
  });

  // ---- Filters UI ----
  function buildChips(container: HTMLElement, values: string[], groupKey: 'category' | 'platform') {
    container.innerHTML = '';
    values.forEach((val) => {
      const chip = document.createElement('button');
      chip.type = 'button';
      chip.className = 'chip' + (state[groupKey] === val ? ' active' : '');
      chip.textContent = val;
      chip.addEventListener('click', () => {
        state[groupKey] = val;
        container.querySelectorAll('.chip').forEach((c) => c.classList.remove('active'));
        chip.classList.add('active');
      });
      container.appendChild(chip);
    });
  }

  function setDefaultDates() {
    const now = new Date();
    const since = new Date(now);
    since.setDate(since.getDate() - 90);
    const until = new Date(now);
    until.setDate(until.getDate() + 90);
    sinceInput.value = fmtDate(since);
    untilInput.value = fmtDate(until);
  }

  applyBtn.addEventListener('click', () => {
    state.page = 1;
    loadReleases(false);
  });

  loadMoreBtn.addEventListener('click', () => {
    state.page += 1;
    loadReleases(true);
  });

  // ---- Releases ----
  function buildQuery(): string {
    const params = new URLSearchParams();
    if (state.category !== 'All') params.set('categories', state.category);
    if (state.platform !== 'All') params.set('platforms', state.platform);
    if (sinceInput.value) params.set('since', sinceInput.value);
    if (untilInput.value) params.set('until', untilInput.value);
    params.set('page', String(state.page));
    return params.toString();
  }

  async function loadReleases(append: boolean) {
    gridStatus.classList.remove('error');
    gridStatus.hidden = false;
    gridStatus.innerHTML = '<span class="spinner"></span> Loading releases…';
    if (!append) {
      grid.innerHTML = '';
      loadMoreBtn.hidden = true;
    }
    applyBtn.disabled = true;
    try {
      const data = await api(`/releases?${buildQuery()}`);
      const games = data.releases || [];
      if (!append && games.length === 0) {
        gridStatus.textContent = 'No releases match these filters.';
      } else {
        gridStatus.hidden = true;
      }
      games.forEach((g: any) => grid.appendChild(renderCard(g)));
      loadMoreBtn.hidden = !data.hasNext;
    } catch (err: any) {
      if (err?.message !== 'Unauthorized') {
        gridStatus.classList.add('error');
        gridStatus.hidden = false;
        gridStatus.textContent = `Could not load releases: ${err?.message || 'unknown error'}`;
      }
    } finally {
      applyBtn.disabled = false;
    }
  }

  function metacriticClass(score: number): string {
    if (score >= 75) return 'high';
    if (score >= 50) return 'mid';
    return 'low';
  }

  function renderCard(game: any): HTMLElement {
    const card = document.createElement('article');
    card.className = 'game-card';

    const platforms: string[] = Array.isArray(game.platforms) ? game.platforms : [];
    const platformHtml = platforms
      .map((p) => `<span class="platform-badge">${escapeHtml(p)}</span>`)
      .join('');

    const mc =
      typeof game.metacriticScore === 'number' && game.metacriticScore > 0
        ? `<span class="metacritic ${metacriticClass(game.metacriticScore)}">${game.metacriticScore}</span>`
        : '';

    const releaseDate = game.releaseDate ? escapeHtml(game.releaseDate) : 'TBA';

    card.innerHTML = `
      <h3>${escapeHtml(game.name || 'Untitled')}</h3>
      <div class="game-meta">
        <span>${releaseDate}</span>
        ${game.category ? `<span class="tag">${escapeHtml(game.category)}</span>` : ''}
        ${mc}
      </div>
      ${platforms.length ? `<div class="platforms">${platformHtml}</div>` : ''}
      ${game.description ? `<p class="game-desc">${escapeHtml(game.description)}</p>` : ''}
      <div class="card-actions">
        <button class="btn rate-btn" type="button">Rate this</button>
      </div>
      <div class="reco" hidden></div>
    `;

    const rateBtn = card.querySelector('.rate-btn') as HTMLButtonElement;
    const recoEl = card.querySelector('.reco') as HTMLElement;
    rateBtn.addEventListener('click', () => rate(game, rateBtn, recoEl));

    return card;
  }

  function confClass(score: number): { text: string; bg: string } {
    if (score >= 75) return { text: 'conf-high', bg: 'conf-high-bg' };
    if (score >= 50) return { text: 'conf-mid', bg: 'conf-mid-bg' };
    return { text: 'conf-low', bg: 'conf-low-bg' };
  }

  async function rate(game: any, btn: HTMLButtonElement, recoEl: HTMLElement) {
    const id = game.rawgId ?? game.id;
    if (id == null) return;
    btn.disabled = true;
    const original = btn.textContent;
    btn.innerHTML = '<span class="spinner"></span> Rating…';
    recoEl.hidden = false;
    recoEl.innerHTML = '<p class="reco-text"><span class="spinner"></span> Asking for a recommendation…</p>';
    try {
      const data = await api('/recommendations', {
        method: 'POST',
        body: JSON.stringify({ gameIds: [id] }),
      });
      const reco = (data.recommendations || [])[0];
      if (!reco) {
        recoEl.innerHTML = '<p class="reco-error">No recommendation returned.</p>';
        return;
      }
      const score = Math.max(0, Math.min(100, Math.round(reco.confidenceScore)));
      const cls = confClass(score);
      recoEl.innerHTML = `
        <div class="reco-head">
          <span class="reco-label">Confidence</span>
          <span class="reco-score ${cls.text}">${score}</span>
        </div>
        <div class="reco-bar"><span class="${cls.bg}" style="width:${score}%"></span></div>
        <p class="reco-text">${escapeHtml(reco.reasoning || '')}</p>
      `;
    } catch (err: any) {
      if (err?.message !== 'Unauthorized') {
        recoEl.innerHTML = `<p class="reco-error">Couldn't rate this: ${escapeHtml(err?.message || 'unknown error')}</p>`;
      }
    } finally {
      btn.disabled = false;
      btn.textContent = original;
    }
  }

  // ---- Init ----
  function initDashboard() {
    buildChips(categoryChips, CATEGORIES, 'category');
    buildChips(platformChips, PLATFORMS, 'platform');
    setDefaultDates();
    loadSyncStatus();
    loadReleases(false);
  }

  // ---- Boot ----
  if (getKey()) {
    showDashboard();
    initDashboard();
  } else {
    showGate();
  }
</script>
